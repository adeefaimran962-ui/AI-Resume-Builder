# MongoDB Atlas Connection String
# Get your connection string from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/DBNAME?retryWrites=true&w=majority
# IMPORTANT: URL-encode username and password if they contain special characters
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/your_database?retryWrites=true&w=majority

# Local MongoDB Fallback
# Set to 'true' to use local MongoDB instead of Atlas
# Local MongoDB must be running on port 27017
USE_LOCAL_DB=false

# Server Configuration
PORT=3000
NODE_ENV=development

# Session Secret (generate a random string for production)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_random_secret_string_here

# Optional: Email Configuration (for future features)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password
