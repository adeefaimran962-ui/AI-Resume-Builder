// ── Add Item Function for Dynamic Sections ─────────────────────────────────────
window.addItem = function(listId, arrayName, fields) {
  console.log('[addItem] Called:', listId, arrayName, fields);
  const list = document.getElementById(listId);
  if (!list) {
    console.error('[addItem] List not found:', listId);
    return;
  }

  const index = list.children.length;
  const item = document.createElement('div');
  item.className = 'dynamic-item';
  item.dataset.index = index;

  // FIXED: Using bracket notation [field] instead of dot notation .field
  let html = '<div class="item-header"><span class="item-title">New Item</span><button type="button" class="btn-remove-item" onclick="removeItem(this)"><i class="fas fa-times"></i></button></div><div class="form-row">';

  fields.forEach(field => {
    const label = field.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase());
    let inputType = 'text';
    let placeholder = '';
    let colClass = 'col-12';

    if (field === 'startDate' || field === 'endDate' || field === 'issueDate' || field === 'date') {
      placeholder = 'Jan 2020';
      colClass = 'col-6';
    } else if (field === 'description') {
      inputType = 'textarea';
      placeholder = 'Description...';
    } else if (field === 'link' || field === 'url') {
      inputType = 'url';
      placeholder = 'https://...';
    } else if (field === 'email') {
      inputType = 'email';
      placeholder = 'email@example.com';
      colClass = 'col-6';
    } else if (field === 'phone') {
      inputType = 'tel';
      placeholder = '+1 234 567 8900';
      colClass = 'col-6';
    } else if (field === 'proficiency') {
      inputType = 'select';
      colClass = 'col-6';
    } else if (field === 'platform') {
      colClass = 'col-4';
      placeholder = 'LinkedIn';
    } else if (['jobTitle', 'company', 'institution', 'degree', 'name', 'organization', 'role'].includes(field)) {
      colClass = 'col-6';
      placeholder = label;
    } else if (['location', 'fieldOfStudy', 'techStack', 'issuer', 'language', 'title'].includes(field)) {
      colClass = field === 'title' ? 'col-8' : 'col-6';
      placeholder = label;
    } else {
      placeholder = label;
      colClass = 'col-12';
    }

    html += '<div class="form-group ' + colClass + '"><label>' + label + '</label>';
    
    if (inputType === 'textarea') {
      html += '<textarea name="' + arrayName + '[' + index + '][' + field + ']" class="form-control" placeholder="' + placeholder + '" rows="3"></textarea>';
    } else if (inputType === 'select' && field === 'proficiency') {
      html += '<select name="' + arrayName + '[' + index + '][' + field + ']" class="form-control">';
      html += '<option value="">Select proficiency</option>';
      html += '<option value="Beginner">Beginner</option>';
      html += '<option value="Elementary">Elementary</option>';
      html += '<option value="Intermediate">Intermediate</option>';
      html += '<option value="Upper-Intermediate">Upper-Intermediate</option>';
      html += '<option value="Advanced">Advanced</option>';
      html += '<option value="Native">Native</option>';
      html += '</select>';
    } else {
      html += '<input type="' + inputType + '" name="' + arrayName + '[' + index + '][' + field + ']" class="form-control" placeholder="' + placeholder + '" />';
    }
    
    html += '</div>';
  });

  html += '</div>';
  item.innerHTML = html;
  list.appendChild(item);

  // Trigger form change
  const form = document.querySelector('.resume-form');
  if (form) {
    form.dispatchEvent(new Event('change'));
  }

  // Update progress
  if (window.updateProgress) window.updateProgress();

  console.log('[addItem] Item added successfully to', listId);
};

// ── Remove Item Function ───────────────────────────────────────────────────────
window.removeItem = function(button) {
  const item = button.closest('.dynamic-item');
  if (!item) return;
  
  const container = item.parentNode;
  item.remove();
  
  // Reindex remaining items
  if (container) {
    const listId = container.id;
    if (listId) window.reindexList(listId);
  }
  
  // Trigger form change
  const form = document.querySelector('.resume-form');
  if (form) {
    form.dispatchEvent(new Event('change'));
  }

  // Update progress
  if (window.updateProgress) window.updateProgress();
};

// ── Global Functions ───────────────────────────────────────────────────────────
window.updateProgress = function() {
  const fields = ['fullName', 'email', 'phone', 'summary', 'skillsRaw'];
  let filled = 0;
  fields.forEach(f => {
    const el = document.querySelector(`[name="${f}"]`);
    if (el && el.value.trim() !== '') filled++;
  });
  const lists = ['workList', 'eduList'];
  lists.forEach(l => {
    const el = document.getElementById(l);
    if (el && el.children.length > 0) filled++;
  });
  const total = fields.length + lists.length; // 7
  const percentage = Math.round((filled / total) * 100);
  const progressText = document.getElementById('progressText');
  const progressFill = document.getElementById('progressFill');
  if (progressText) progressText.innerText = `${percentage}%`;
  if (progressFill) progressFill.style.width = `${percentage}%`;
};

window.reindexList = function(listId) {
  const list = document.getElementById(listId);
  if (!list) return;
  const items = list.querySelectorAll('.dynamic-item');
  items.forEach((item, index) => {
    const inputs = item.querySelectorAll('input, select, textarea');
    inputs.forEach(input => {
      const name = input.name;
      if (name) {
        input.name = name.replace(/\[\d+\]/, `[${index}]`);
      }
    });
    item.dataset.index = index;
    
    // Update item number
    const numberEl = item.querySelector('.item-number');
    if (numberEl) numberEl.textContent = index + 1;
  });
};

document.addEventListener('DOMContentLoaded', function() {
  const resumeForm = document.querySelector('.resume-form');
  if (!resumeForm) return;

  // 1. Progress Indicator
  resumeForm.addEventListener('input', window.updateProgress);
  setTimeout(window.updateProgress, 100);

  // 2. Sortable JS
  const listsToSort = ['workList', 'eduList', 'projectList', 'certList', 'langList', 'achieveList', 'socialList', 'skillsList', 'referencesList', 'volunteerList', 'interestsList'];
  listsToSort.forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      new Sortable(el, {
        animation: 150,
        handle: '.item-header',
        onEnd: function() {
          formChanged = true;
          window.reindexList(id);
          triggerLivePreview();
        }
      });
    }
  });

  // 3. Unsaved Changes, Auto-save & Live Preview
  let formChanged = false;
  let previewDebounce;
  
  resumeForm.addEventListener('change', () => { formChanged = true; triggerLivePreview(); });
  resumeForm.addEventListener('input',  () => { formChanged = true; triggerLivePreview(); });
  
  window.addEventListener('beforeunload', (e) => {
    if (formChanged) {
      e.preventDefault();
      e.returnValue = '';
    }
  });

  resumeForm.addEventListener('submit', () => {
    formChanged = false; // prevent warning on intentional submit
  });

  async function performAutoSave(isLivePreview = false) {
    if (!formChanged) return;
    if (!resumeForm.action.includes('/resume/')) return; // only auto-save in edit mode
    
    setAutoSaveStatus('saving');
    const formData = new FormData(resumeForm);
    const data = new URLSearchParams(formData);
    
    try {
      const res = await fetch(resumeForm.action, {
        method: resumeForm.method,
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
        body: data
      });
      if (!res.ok) throw new Error('Server error ' + res.status);
      const result = await res.json();
      if (result.success) {
        formChanged = false;
        const now = new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
        setAutoSaveStatus('saved', now);
        if (!isLivePreview && window.showToast) window.showToast('Auto-saved ✓', 'success');
        if (result.id && resumeForm.action.endsWith('/resume')) {
           resumeForm.action = `/resume/${result.id}?_method=PUT`;
           const pf = document.getElementById('previewFrame');
           if (pf) pf.src = `/resume/${result.id}/preview`;
        } else if (isLivePreview) {
           const pf = document.getElementById('previewFrame');
           if (pf && pf.contentWindow) pf.contentWindow.location.reload();
        }
      } else {
        setAutoSaveStatus('error');
      }
    } catch (e) {
      console.error('Auto-save failed', e);
      setAutoSaveStatus('error');
    }
  }

  function triggerLivePreview() {
    const panel = document.getElementById('previewPanel');
    if (panel && panel.style.display === 'block') {
      clearTimeout(previewDebounce);
      previewDebounce = setTimeout(() => { performAutoSave(true); }, 1000);
    }
  }

  // Auto-save every 30 seconds if there are unsaved changes
  setInterval(() => { performAutoSave(false); }, 30000);

  // 4. AI Generate buttons — with loading + error states
  document.querySelectorAll('[data-ai-generate]').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      const type   = this.getAttribute('data-ai-generate');
      const target = this.getAttribute('data-target');
      const field  = target ? document.getElementById(target) : null;
      if (!field) { if(window.showToast) window.showToast('Target field not found.', 'error'); return; }

      // Read context from the form
      const jobTitle = (document.querySelector('[name="jobTitle"]') || {}).value || '';
      const company  = (document.querySelector('[name="company"]')  || {}).value || '';
      const skillsEl = document.querySelector('[name="skillsRaw"]');
      const skills   = skillsEl ? skillsEl.value : '';

      // Loading state
      const origHTML = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generating…';

      try {
        const res = await fetch('/resume/ai/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type, jobTitle, company, skills, inputText: field.value, years: 3 })
        });
        if (!res.ok) throw new Error('Server error');
        const data = await res.json();
        if (data.success && data.result) {
          field.value = data.result;
          field.dispatchEvent(new Event('input', { bubbles: true }));
          formChanged = true;
          if (window.showToast) window.showToast('AI content generated!', 'success');
        } else {
          if (window.showToast) window.showToast('AI generation failed. Try again.', 'error');
        }
      } catch(e) {
        console.error('AI generate error:', e);
        if (window.showToast) window.showToast('Error connecting to AI service.', 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = origHTML;
      }
    });
  });
});
</script>

