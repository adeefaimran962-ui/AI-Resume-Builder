<!-- Live Preview Panel -->
<div id="previewPanel" style="display:none; position:fixed; right:0; top:0; width:50%; height:100vh; background:var(--white); z-index:9999; border-left:1px solid var(--border); box-shadow:-4px 0 15px rgba(0,0,0,0.05); transition: transform 0.3s ease;">
  <div style="padding:14px 20px; background:var(--bg-2); border-bottom:1px solid var(--border); display:flex; justify-content:space-between; align-items:center;">
    <strong style="color:var(--dark);"><i class="fas fa-eye" style="color:var(--primary); margin-right:6px;"></i> Live Preview</strong>
    <button onclick="togglePreview()" class="btn btn-sm btn-outline"><i class="fas fa-times"></i> Close</button>
  </div>
  <iframe id="previewFrame" src="<%= resume ? '/resume/'+resume._id+'/preview' : '' %>" style="width:100%; height:calc(100% - 58px); border:none;"></iframe>
</div>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
<script>
function togglePreview() {
  const panel = document.getElementById('previewPanel');
  const main = document.querySelector('.form-page');
  if (panel.style.display === 'none' || panel.style.display === '') {
    panel.style.display = 'block';
    main.style.marginRight = '50%';
    main.style.transition = 'margin-right 0.3s ease';
  } else {
    panel.style.display = 'none';
    main.style.marginRight = '0';
  }
}

// ── Auto-save status helpers ─────────────────────────────────────────────────
function setAutoSaveStatus(state, time) {
  const icon = document.getElementById('autoSaveIcon');
  const statusEl = document.getElementById('autoSaveStatus');
  const timeEl = document.getElementById('autoSaveTime');
  if (!statusEl) return;
  if (state === 'saving') {
    if(icon) { icon.className = 'fas fa-spinner fa-spin'; icon.style.color = 'var(--primary)'; }
    statusEl.textContent = 'Saving…';
    statusEl.style.color = 'var(--primary)';
  } else if (state === 'saved') {
    if(icon) { icon.className = 'fas fa-check-circle'; icon.style.color = 'var(--success)'; }
    statusEl.textContent = 'Saved successfully';
    statusEl.style.color = 'var(--success)';
    if (time && timeEl) timeEl.textContent = 'Last saved: ' + time;
    setTimeout(() => {
      if(icon) { icon.className = 'fas fa-cloud'; icon.style.color = 'var(--muted)'; }
      statusEl.textContent = 'Changes will be auto-saved every 30 seconds';
      statusEl.style.color = 'var(--muted)';
    }, 3000);
  } else if (state === 'error') {
    if(icon) { icon.className = 'fas fa-exclamation-triangle'; icon.style.color = 'var(--danger)'; }
    statusEl.textContent = 'Auto-save failed. Your changes are not lost — save manually.';
    statusEl.style.color = 'var(--danger)';
  }
}

// ── Profile Photo: Drag & Drop + Click Upload ────────────────────────────────
(function () {
  var input = document.getElementById('profilePhotoInput');
  if (!input) return; // create mode — no photo input rendered

  var RESUME_ID = '<%= resume ? resume._id : "" %>';
  var dragZone = document.getElementById('photoDragZone');
  var overlay = document.getElementById('photoDragOverlay');

  // Drag & Drop events on the zone
  if (dragZone) {
    ['dragenter','dragover'].forEach(function(ev) {
      dragZone.addEventListener(ev, function(e) {
        e.preventDefault();
        if (overlay) overlay.style.display = 'flex';
        dragZone.style.borderColor = 'var(--primary)';
      });
    });
    ['dragleave','dragend'].forEach(function(ev) {
      dragZone.addEventListener(ev, function(e) {
        if (overlay) overlay.style.display = 'none';
        dragZone.style.borderColor = 'var(--border)';
      });
    });
    dragZone.addEventListener('drop', function(e) {
      e.preventDefault();
      if (overlay) overlay.style.display = 'none';
      dragZone.style.borderColor = 'var(--border)';
      const file = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
      if (file) handlePhotoFile(file);
    });
  }

  // Also handle the page-wide drop (if user drops outside zone)
  document.addEventListener('dragover', function(e) { e.preventDefault(); });

  input.addEventListener('change', function () {
    if (this.files[0]) handlePhotoFile(this.files[0]);
  });

  function handlePhotoFile(file) {
    var errEl  = document.getElementById('photoError');
    var errMsg = errEl ? errEl.querySelector('span') : null;
    if (errEl) errEl.style.display = 'none';

    // Client-side validation
    var allowed = ['image/jpeg', 'image/png', 'image/webp'];
    if (!allowed.includes(file.type)) {
      if (errMsg) errMsg.textContent = 'Only JPG, PNG, and WebP images are allowed.';
      if (errEl) errEl.style.display = 'block';
      return;
    }
    if (file.size > 2 * 1024 * 1024) {
      if (errMsg) errMsg.textContent = 'File is too large. Maximum size is 2 MB.';
      if (errEl) errEl.style.display = 'block';
      return;
    }

    // Show optimistic preview immediately
    var reader = new FileReader();
    reader.onload = function (e) {
      var preview = document.getElementById('photoPreview');
      var icon = document.getElementById('photoPlaceholderIcon');
      var text = document.getElementById('photoPlaceholderText');
      if (preview) { preview.src = e.target.result; preview.style.display = 'block'; }
      if (icon) icon.style.display = 'none';
      if (text) text.style.display = 'none';
    };
    reader.readAsDataURL(file);

    // Upload via dedicated multipart endpoint
    var status = document.getElementById('photoStatus');
    if (status) { status.textContent = 'Uploading…'; status.style.display = 'block'; status.style.color = 'var(--primary)'; }

    var fd = new FormData();
    fd.append('profilePhoto', file);

    fetch('/resume/' + RESUME_ID + '/upload-photo', { method: 'POST', body: fd })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.success) {
        var preview = document.getElementById('photoPreview');
        if (preview) { preview.src = data.photoUrl; preview.style.display = 'block'; }
        var icon = document.getElementById('photoPlaceholderIcon');
        var text = document.getElementById('photoPlaceholderText');
        if (icon) icon.style.display = 'none';
        if (text) text.style.display = 'none';
        var removeBtn = document.getElementById('removePhotoBtn');
        if (removeBtn) removeBtn.style.display = 'flex';
        if (status) { status.textContent = '✓ Photo saved.'; status.style.color = 'var(--success)'; setTimeout(function(){ status.style.display='none'; }, 2500); }
        if (window.showToast) window.showToast('Profile photo uploaded!', 'success');
      } else {
        if (status) status.style.display = 'none';
        if (errMsg) errMsg.textContent = data.message || 'Upload failed. Please try again.';
        if (errEl) errEl.style.display = 'block';
      }
    })
    .catch(function () {
      if (status) status.style.display = 'none';
      if (errMsg) errMsg.textContent = 'Upload failed. Please check your connection.';
      if (errEl) errEl.style.display = 'block';
    });
  }

  window.removePhoto = function () {
    if (!RESUME_ID) return;
    fetch('/resume/' + RESUME_ID + '/remove-photo', { method: 'POST' })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.success) {
        var preview = document.getElementById('photoPreview');
        if (preview) { preview.src = ''; preview.style.display = 'none'; }
        var icon = document.getElementById('photoPlaceholderIcon');
        var text = document.getElementById('photoPlaceholderText');
        if (icon) { icon.style.display = ''; }
        if (text) { text.style.display = ''; }
        var removeBtn = document.getElementById('removePhotoBtn');
        if (removeBtn) removeBtn.style.display = 'none';
        input.value = '';
        if (window.showToast) window.showToast('Photo removed.', 'info');
      }
    })
    .catch(function () {
      if (window.showToast) window.showToast('Could not remove photo.', 'error');
    });
  };

  // ── Load Existing Cover Letter ─────────────────────────────────────────────
  window.loadExistingCoverLetter = function () {
    if (!RESUME_ID) return;
    fetch('/cover-letter/by-resume/' + RESUME_ID)
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.success && data.coverLetter) {
          var clDiv = document.getElementById('existingCoverLetter');
          var clTitle = document.getElementById('clTitle');
          var clJobTitle = document.getElementById('clJobTitle');
          var clEditLink = document.getElementById('clEditLink');
          var clPreviewLink = document.getElementById('clPreviewLink');
          
          if (clDiv) clDiv.style.display = 'block';
          if (clTitle) clTitle.textContent = data.coverLetter.title;
          if (clJobTitle) clJobTitle.textContent = data.coverLetter.jobTitle ? 'Position: ' + data.coverLetter.jobTitle : '';
          if (clEditLink) clEditLink.href = '/cover-letter/' + data.coverLetter._id + '/edit';
          if (clPreviewLink) clPreviewLink.href = '/cover-letter/' + data.coverLetter._id + '/preview';
          
          if (window.showToast) window.showToast('Cover letter loaded!', 'success');
        } else {
          if (window.showToast) window.showToast('No cover letter found for this resume.', 'info');
        }
      })
      .catch(function (e) {
        console.error('Error loading cover letter:', e);
        if (window.showToast) window.showToast('Error loading cover letter.', 'error');
      });
  };
}());
