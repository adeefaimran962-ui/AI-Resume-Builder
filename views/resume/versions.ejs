<%- include("../partials/header") %>

<div class="dashboard-layout">

  <!-- ═══ SIDEBAR ══════════════════════════════════════════════ -->
  <aside class="sidebar" id="dashSidebar">
    <div class="sidebar-logo">
      <a href="/">
        <span class="brand-icon-wrap"><i class="fas fa-bolt"></i></span>
        <span>ResumeAI<span style="color:var(--accent)">.</span></span>
      </a>
    </div>

    <nav class="sidebar-nav">
      <span class="sidebar-nav-section">Main</span>
      <a href="/dashboard" class="sidebar-nav-item">
        <i class="fas fa-th-large"></i> Dashboard
      </a>
      <a href="/resume/new" class="sidebar-nav-item">
        <i class="fas fa-plus-circle"></i> New Resume
      </a>

      <span class="sidebar-nav-section" style="margin-top:12px">Manage</span>
      <a href="/dashboard" class="sidebar-nav-item">
        <i class="fas fa-folder-open"></i> My Resumes
      </a>
      <a href="/dashboard/trash" class="sidebar-nav-item">
        <i class="fas fa-trash-alt"></i> Trash
      </a>

      <span class="sidebar-nav-section" style="margin-top:12px">Account</span>
      <a href="/dashboard/profile" class="sidebar-nav-item">
        <i class="fas fa-user-circle"></i> Profile
      </a>
    </nav>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <% if (currentUser.avatar) { %>
          <img src="<%= currentUser.avatar %>" alt="Avatar" class="sidebar-user-avatar" style="width:36px;height:36px;border-radius:50%;object-fit:cover;">
        <% } else { %>
          <div class="sidebar-user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></div>
        <% } %>
        <div style="overflow:hidden">
          <div class="sidebar-user-name"><%= currentUser.name %></div>
          <div class="sidebar-user-email"><%= currentUser.email %></div>
        </div>
      </div>
      <a href="/auth/logout" class="sidebar-logout">
        <i class="fas fa-sign-out-alt"></i> Logout
      </a>
    </div>
  </aside>

  <!-- ═══ MAIN CONTENT ════════════════════════════════════════ -->
  <div class="dashboard-main">

    <!-- TOP BAR -->
    <header class="topbar">
      <div style="display:flex;align-items:center;gap:14px">
        <button class="sidebar-toggle-btn" id="sidebarToggle" aria-label="Toggle sidebar">
          <i class="fas fa-bars"></i>
        </button>
        <span class="topbar-title">Version History</span>
      </div>
      <div class="topbar-actions">
        <a href="/resume/<%= resume._id %>/preview" class="btn btn-secondary btn-sm">
          <i class="fas fa-arrow-left"></i> Back to Preview
        </a>
      </div>
    </header>

    <!-- PAGE CONTENT -->
    <div class="page-content">
      <%- include("../partials/flash") %>

      <!-- HEADER -->
      <div class="page-header">
        <div>
          <h1>Version History</h1>
          <p class="text-muted">Track and restore previous versions of "<%= resume.title %>"</p>
        </div>
      </div>

      <!-- VERSIONS LIST -->
      <div class="card">
        <% if (versions.length === 0) { %>
          <div class="empty-state">
            <i class="fas fa-history" style="font-size:48px;color:var(--muted);margin-bottom:16px;"></i>
            <h3>No versions yet</h3>
            <p class="text-muted">Versions are automatically created when you update your resume.</p>
            <a href="/resume/<%= resume._id %>/edit" class="btn btn-primary">
              <i class="fas fa-edit"></i> Edit Resume
            </a>
          </div>
        <% } else { %>
          <div class="versions-list">
            <% versions.forEach((version, index) => { %>
              <div class="version-item">
                <div class="version-info">
                  <div class="version-number">
                    <span class="version-badge">v<%= version.versionNumber %></span>
                    <% if (index === 0) { %>
                      <span class="version-latest">Latest</span>
                    <% } %>
                  </div>
                  <div class="version-meta">
                    <div class="version-date">
                      <i class="fas fa-calendar-alt"></i>
                      <%= new Date(version.createdAt).toLocaleDateString('en-US', { 
                        year: 'numeric', 
                        month: 'short', 
                        day: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                      }) %>
                    </div>
                    <div class="version-ats">
                      <i class="fas fa-chart-line"></i>
                      ATS Score: <%= version.snapshot.atsScore || 0 %>%
                    </div>
                  </div>
                </div>
                <div class="version-actions">
                  <a href="/resume/<%= resume._id %>/versions/<%= version.versionNumber %>" 
                     class="btn btn-sm btn-secondary" 
                     title="Preview this version">
                    <i class="fas fa-eye"></i> Preview
                  </a>
                  <form action="/resume/<%= resume._id %>/versions/<%= version.versionNumber %>/restore" 
                        method="POST" 
                        style="display:inline;">
                    <button type="submit" 
                            class="btn btn-sm btn-primary" 
                            title="Restore this version"
                            onclick="return confirm('Are you sure you want to restore version <%= version.versionNumber %>? Your current version will be saved as a new version before restoring.')">
                      <i class="fas fa-undo"></i> Restore
                    </button>
                  </form>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>

      <!-- INFO CARD -->
      <div class="card" style="margin-top:24px;background:var(--info-bg);border:1px solid var(--info-border);">
        <div style="display:flex;gap:12px;align-items:flex-start;">
          <i class="fas fa-info-circle" style="color:var(--info-color);font-size:20px;margin-top:2px;"></i>
          <div>
            <h4 style="margin:0 0 8px 0;color:var(--info-color);">About Version History</h4>
            <p style="margin:0;color:var(--text-muted);font-size:14px;line-height:1.6;">
              Every time you update your resume, a snapshot is automatically saved. You can preview any previous version and restore it if needed. Restoring a version will save your current version as a new version before applying the restore, so you never lose any changes.
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
.versions-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.version-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 8px;
  transition: all 0.2s ease;
}

.version-item:hover {
  border-color: var(--accent);
  box-shadow: 0 2px 8px rgba(108, 99, 255, 0.1);
}

.version-info {
  flex: 1;
}

.version-number {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.version-badge {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  background: var(--accent);
  color: white;
  border-radius: 20px;
  font-weight: 600;
  font-size: 13px;
}

.version-latest {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  background: #10b981;
  color: white;
  border-radius: 20px;
  font-weight: 600;
  font-size: 11px;
  text-transform: uppercase;
}

.version-meta {
  display: flex;
  gap: 20px;
  font-size: 13px;
  color: var(--text-muted);
}

.version-date,
.version-ats {
  display: flex;
  align-items: center;
  gap: 6px;
}

.version-actions {
  display: flex;
  gap: 8px;
}

.empty-state {
  text-align: center;
  padding: 48px 24px;
}

.empty-state i {
  margin-bottom: 16px;
}

.empty-state h3 {
  margin: 0 0 8px 0;
  color: var(--text);
}

.empty-state p {
  margin: 0 0 24px 0;
  color: var(--text-muted);
}
</style>

<%- include("../partials/footer") %>
