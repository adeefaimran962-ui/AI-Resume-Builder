<%# MODERN TEMPLATE: Purple gradient sidebar + clean right column %>
<div class="tpl-modern">

  <%# HEADER %>
  <div class="tpl-m-header">
    <div class="tpl-m-header-content">
      <h1 class="tpl-m-name"><%= resume.personalInfo.fullName || resume.title %></h1>
      <% if (resume.personalInfo.jobTitle) { %>
        <p class="tpl-m-role"><%= resume.personalInfo.jobTitle %></p>
      <% } %>
      <div class="tpl-m-contact">
        <% if (resume.personalInfo.email) { %><span><i class="fas fa-envelope"></i> <%= resume.personalInfo.email %></span><% } %>
        <% if (resume.personalInfo.phone) { %><span><i class="fas fa-phone"></i> <%= resume.personalInfo.phone %></span><% } %>
        <% if (resume.personalInfo.city) { %><span><i class="fas fa-map-marker-alt"></i> <%= resume.personalInfo.city %><% if(resume.personalInfo.country){ %>, <%= resume.personalInfo.country %><% } %></span><% } %>
        <% if (resume.personalInfo.website) { %><span><i class="fas fa-globe"></i> <%= resume.personalInfo.website %></span><% } %>
        <% if (resume.personalInfo.linkedin) { %><span><i class="fab fa-linkedin"></i> <%= resume.personalInfo.linkedin %></span><% } %>
        <% if (resume.personalInfo.github) { %><span><i class="fab fa-github"></i> <%= resume.personalInfo.github %></span><% } %>
      </div>
    </div>
  </div>

  <%# BODY: sidebar + main %>
  <div class="tpl-m-body">

    <%# LEFT SIDEBAR %>
    <aside class="tpl-m-sidebar">

      <% if (resume.skills && resume.skills.length) { %>
      <div class="tpl-m-section">
        <h2 class="tpl-m-section-title">Skills</h2>
        <div class="tpl-m-skills">
          <% resume.skills.forEach(function(s){ %><span class="tpl-m-skill-tag"><%= s %></span><% }); %>
        </div>
      </div>
      <% } %>

      <% if (resume.languages && resume.languages.length) { %>
      <div class="tpl-m-section">
        <h2 class="tpl-m-section-title">Languages</h2>
        <% resume.languages.forEach(function(l){ %>
        <div class="tpl-m-lang-row">
          <span class="tpl-m-lang-name"><%= l.language %></span>
          <span class="tpl-m-lang-badge"><%= l.proficiency %></span>
        </div>
        <% }); %>
      </div>
      <% } %>

      <% if (resume.certifications && resume.certifications.length) { %>
      <div class="tpl-m-section">
        <h2 class="tpl-m-section-title">Certifications</h2>
        <% resume.certifications.forEach(function(c){ %>
        <div class="tpl-m-cert">
          <strong><%= c.name %></strong>
          <% if(c.issuer){ %><span><%= c.issuer %></span><% } %>
          <% if(c.issueDate){ %><span><%= c.issueDate %></span><% } %>
        </div>
        <% }); %>
      </div>
      <% } %>

      <% if (resume.socialLinks && resume.socialLinks.length) { %>
      <div class="tpl-m-section">
        <h2 class="tpl-m-section-title">Links</h2>
        <% resume.socialLinks.forEach(function(s){ %>
        <div class="tpl-m-link"><i class="fas fa-link"></i> <% if(s.platform){ %><strong><%= s.platform %>:</strong> <% } %><%= s.url %></div>
        <% }); %>
      </div>
      <% } %>

    </aside>

    <%# MAIN RIGHT COLUMN %>
    <main class="tpl-m-main">

      <% if (resume.summary) { %>
      <div class="tpl-m-section">
        <h2 class="tpl-m-section-title-right">Professional Summary</h2>
        <p class="tpl-m-summary"><%= resume.summary %></p>
      </div>
      <% } %>

      <% if (resume.workExperience && resume.workExperience.length) { %>
      <div class="tpl-m-section">
        <h2 class="tpl-m-section-title-right">Work Experience</h2>
        <% resume.workExperience.forEach(function(w){ %>
        <div class="tpl-m-exp-item">
          <div class="tpl-m-exp-top">
            <span class="tpl-m-exp-title"><%= w.jobTitle %></span>
            <span class="tpl-m-exp-dates"><%= w.startDate %> &ndash; <%= w.current ? 'Present' : w.endDate %></span>
          </div>
          <div class="tpl-m-exp-company"><%= w.company %><% if(w.location){ %> &bull; <%= w.location %><% } %></div>
          <% if(w.description){ %><p class="tpl-m-exp-desc"><%= w.description %></p><% } %>
        </div>
        <% }); %>
      </div>
      <% } %>

      <% if (resume.education && resume.education.length) { %>
      <div class="tpl-m-section">
        <h2 class="tpl-m-section-title-right">Education</h2>
        <% resume.education.forEach(function(e){ %>
        <div class="tpl-m-exp-item">
          <div class="tpl-m-exp-top">
            <span class="tpl-m-exp-title"><%= e.degree %><% if(e.fieldOfStudy){ %> in <%= e.fieldOfStudy %><% } %></span>
            <span class="tpl-m-exp-dates"><%= e.startDate %> &ndash; <%= e.endDate %></span>
          </div>
          <div class="tpl-m-exp-company"><%= e.institution %></div>
          <% if(e.description){ %><p class="tpl-m-exp-desc"><%= e.description %></p><% } %>
        </div>
        <% }); %>
      </div>
      <% } %>

      <% if (resume.projects && resume.projects.length) { %>
      <div class="tpl-m-section">
        <h2 class="tpl-m-section-title-right">Projects</h2>
        <% resume.projects.forEach(function(p){ %>
        <div class="tpl-m-exp-item">
          <div class="tpl-m-exp-top">
            <span class="tpl-m-exp-title"><%= p.name %></span>
            <% if(p.link){ %><a href="<%= p.link %>" class="tpl-m-proj-link" target="_blank"><i class="fas fa-external-link-alt"></i></a><% } %>
          </div>
          <% if(p.techStack){ %><div class="tpl-m-exp-company"><%= p.techStack %></div><% } %>
          <% if(p.description){ %><p class="tpl-m-exp-desc"><%= p.description %></p><% } %>
        </div>
        <% }); %>
      </div>
      <% } %>

      <% if (resume.achievements && resume.achievements.length) { %>
      <div class="tpl-m-section">
        <h2 class="tpl-m-section-title-right">Achievements</h2>
        <% resume.achievements.forEach(function(a){ %>
        <div class="tpl-m-exp-item">
          <div class="tpl-m-exp-top">
            <span class="tpl-m-exp-title"><%= a.title %></span>
            <% if(a.date){ %><span class="tpl-m-exp-dates"><%= a.date %></span><% } %>
          </div>
          <% if(a.description){ %><p class="tpl-m-exp-desc"><%= a.description %></p><% } %>
        </div>
        <% }); %>
      </div>
      <% } %>

    </main>
  </div>
</div>
