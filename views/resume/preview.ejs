<%- include("../partials/header") %>
<%- include("../partials/navbar") %>
<main class="preview-page">
  <div class="container">
    <%- include("../partials/flash") %>

    <% if (!locals.isShared) { %>
    <div class="preview-toolbar">
      <a href="/dashboard" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Dashboard</a>
      <div class="preview-actions">

        <!-- Template Switcher -->
        <div class="tpl-switcher" id="tplSwitcher">
          <span class="tpl-switcher-label"><i class="fas fa-palette"></i></span>
          <% ['modern','classic','minimal','professional','executive','creative','compact','tech','elegant'].forEach(function(t){ %>
          <a href="/resume/<%= resume._id %>/preview?tpl=<%= t %>"
             class="tpl-chip <%= (tpl===t)?'active':'' %>"
             title="<%= t.charAt(0).toUpperCase()+t.slice(1) %>"
             data-tpl="<%= t %>">
            <%= t.charAt(0).toUpperCase()+t.slice(1) %>
          </a>
          <% }); %>
        </div>

        <a href="/resume/<%= resume._id %>/match" class="btn btn-outline"><i class="fas fa-bullseye"></i> Job Match</a>
        <a href="/resume/<%= resume._id %>/score" class="btn btn-outline" style="color:var(--accent);border-color:var(--accent)"><i class="fas fa-chart-pie"></i> ATS Score</a>
        <a href="/resume/<%= resume._id %>/edit" class="btn btn-outline"><i class="fas fa-edit"></i> Edit</a>

        <div class="dropdown-wrapper" style="position:relative;display:inline-block;">
          <button class="btn btn-primary" id="dlBtn"><i class="fas fa-download"></i> Download <i class="fas fa-caret-down"></i></button>
          <div id="dlMenu" style="display:none;position:absolute;top:100%;right:0;background:#fff;border:1px solid var(--border);border-radius:8px;box-shadow:var(--shadow-card);z-index:100;min-width:150px;margin-top:4px;">
            <a href="/resume/<%= resume._id %>/download" style="display:block;padding:10px 16px;color:var(--dark);text-decoration:none;" id="dlPdfBtn"><i class="fas fa-file-pdf"></i> PDF</a>
            <a href="/resume/<%= resume._id %>/download-docx" style="display:block;padding:10px 16px;color:var(--dark);text-decoration:none;"><i class="fas fa-file-word"></i> DOCX</a>
          </div>
        </div>

        <button class="btn btn-outline" id="shareBtn" onclick="toggleShare('<%= resume._id %>')">
          <i class="fas <%= resume.isPublic ? 'fa-share-alt' : 'fa-lock' %>"></i>
          <span id="shareBtnText"><%= resume.isPublic ? 'Public' : 'Private' %></span>
        </button>
      </div>
    </div>
    <script>
      // Download dropdown
      document.getElementById('dlBtn').addEventListener('click', function(e){
        e.stopPropagation();
        const menu = document.getElementById('dlMenu');
        menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
      });

      // PDF loading state
      document.getElementById('dlPdfBtn').addEventListener('click', function(){
        if(window.showToast) window.showToast('Generating PDF, please wait…', 'info');
      });

      document.addEventListener('click', function(e) {
        if (!e.target.closest('.dropdown-wrapper')) {
          const menu = document.getElementById('dlMenu');
          if(menu) menu.style.display = 'none';
        }
      });

      function toggleShare(id) {
        fetch('/resume/' + id + '/toggle-share', { method: 'POST' })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              const btn = document.getElementById('shareBtn');
              if (data.isPublic) {
                btn.innerHTML = '<i class="fas fa-share-alt"></i> <span id="shareBtnText">Public</span>';
                const url = window.location.origin + '/shared/' + id;
                navigator.clipboard.writeText(url).then(() => {
                  if (window.showToast) window.showToast('Sharing enabled! Link copied.', 'success');
                });
              } else {
                btn.innerHTML = '<i class="fas fa-lock"></i> <span id="shareBtnText">Private</span>';
                if (window.showToast) window.showToast('Sharing disabled.', 'info');
              }
            }
          });
      }

      // Template switching with loading indicator
      document.querySelectorAll('.tpl-chip').forEach(function(chip){
        chip.addEventListener('click', function(e){
          e.preventDefault();
          const tpl = this.dataset.tpl;
          document.querySelectorAll('.tpl-chip').forEach(c=>c.classList.remove('active'));
          this.classList.add('active');
          if(window.showToast) window.showToast('Switching to ' + tpl.charAt(0).toUpperCase()+tpl.slice(1) + ' template…', 'info');
          // Save template and redirect
          fetch('/resume/<%= resume._id %>/set-template', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({template: tpl})
          }).then(r=>r.json()).then(d=>{
            if(d.success) window.location.reload();
          }).catch(()=>{
            window.location.href = this.href;
          });
        });
      });
    </script>
    <% } %>

    <div class="preview-template-badge">
      <i class="fas fa-palette"></i>
      Using: <strong><%= tpl.charAt(0).toUpperCase() + tpl.slice(1) %></strong> template
    </div>

    <div class="resume-preview-wrapper tpl-canvas-<%= tpl %>">
      <% if (tpl === 'classic') { %>
        <%- include("templates/classic") %>
      <% } else if (tpl === 'minimal') { %>
        <%- include("templates/minimal") %>
      <% } else if (tpl === 'professional') { %>
        <%- include("templates/professional") %>
      <% } else if (tpl === 'executive') { %>
        <%- include("templates/executive") %>
      <% } else if (tpl === 'creative') { %>
        <%- include("templates/creative") %>
      <% } else if (tpl === 'compact') { %>
        <%- include("templates/compact") %>
      <% } else if (tpl === 'tech') { %>
        <%- include("templates/tech") %>
      <% } else if (tpl === 'elegant') { %>
        <%- include("templates/elegant") %>
      <% } else { %>
        <%- include("templates/modern") %>
      <% } %>
    </div>

  </div>
</main>
<%- include("../partials/footer") %>

