<%- include("../partials/header") %>
<%- include("../partials/navbar") %>
<main class="preview-page">
  <div class="container">
    <%- include("../partials/flash") %>

    <div class="preview-toolbar">
      <a href="/dashboard" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Dashboard</a>
      <div class="preview-actions">
        <div class="tpl-switcher">
          <span class="tpl-switcher-label"><i class="fas fa-layer-group"></i> Template:</span>
          <a href="/resume/<%= resume._id %>/edit" class="tpl-chip <%= resume.template === 'modern'  ? 'active' : '' %>">Modern</a>
          <a href="/resume/<%= resume._id %>/edit" class="tpl-chip <%= resume.template === 'classic' ? 'active' : '' %>">Classic</a>
          <a href="/resume/<%= resume._id %>/edit" class="tpl-chip <%= resume.template === 'minimal' ? 'active' : '' %>">Minimal</a>
        </div>
        <a href="/resume/<%= resume._id %>/edit"     class="btn btn-outline"><i class="fas fa-edit"></i> Edit</a>
        <a href="/resume/<%= resume._id %>/download" class="btn btn-primary"><i class="fas fa-download"></i> Download PDF</a>
      </div>
    </div>

    <div class="preview-template-badge">
      <i class="fas fa-palette"></i>
      Using: <strong><%= resume.template.charAt(0).toUpperCase() + resume.template.slice(1) %></strong> template
    </div>

    <div class="resume-preview-wrapper tpl-canvas-<%= resume.template %>">
      <% if (resume.template === 'classic') { %>
        <%- include("templates/classic") %>
      <% } else if (resume.template === 'minimal') { %>
        <%- include("templates/minimal") %>
      <% } else { %>
        <%- include("templates/modern") %>
      <% } %>
    </div>

  </div>
</main>
<%- include("../partials/footer") %>
