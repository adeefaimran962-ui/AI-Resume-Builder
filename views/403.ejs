<%- include("partials/header") %>
<style>
  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-2);
    padding: 40px 20px;
  }
  .error-content {
    text-align: center;
    max-width: 600px;
  }
  .error-illustration {
    width: 200px;
    height: 200px;
    margin: 0 auto 30px;
    background: var(--bg-3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 80px;
    color: var(--danger);
  }
  .error-code {
    font-size: 120px;
    font-weight: 800;
    color: var(--danger);
    line-height: 1;
    margin-bottom: 20px;
  }
  .error-title {
    font-size: 32px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 16px;
  }
  .error-message {
    font-size: 18px;
    color: var(--text-2);
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .error-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .error-actions .btn {
    min-width: 140px;
  }
</style>
<main class="error-page">
  <div class="error-content">
    <div class="error-illustration">
      <i class="fas fa-ban"></i>
    </div>
    <div class="error-code">403</div>
    <h1 class="error-title">Access Denied</h1>
    <p class="error-message">
      You don't have permission to access this page. If you believe this is an error, please contact support.
    </p>
    <div class="error-actions">
      <a href="/dashboard" class="btn btn-primary">
        <i class="fas fa-th-large"></i> Dashboard
      </a>
      <a href="/" class="btn btn-outline">
        <i class="fas fa-home"></i> Home
      </a>
    </div>
  </div>
</main>
<%- include("partials/footer") %>
