<%- include('../partials/header') %>

<div class="dashboard-container">
  <div class="dashboard-main">
    <div class="dashboard-header">
      <div class="dashboard-title-section">
        <h1 class="dashboard-title">
          <i class="fas fa-chart-line"></i>
          Skill Gap Analyzer
        </h1>
        <p class="dashboard-subtitle">Identify skill gaps and get personalized learning recommendations for your target role</p>
      </div>
    </div>

    <div class="analyzer-content">
      <!-- Analyzer Form -->
      <div class="analyzer-section">
        <h2 class="section-title">
          <i class="fas fa-search"></i>
          Analyze Your Skills
        </h2>
        
        <form id="skillGapForm" class="skill-gap-form">
          <div class="form-grid">
            <div class="form-group">
              <label for="resumeId" class="form-label">Select Your Resume</label>
              <select id="resumeId" name="resumeId" class="form-select">
                <option value="">Select a resume to analyze...</option>
                <% resumes.forEach(function(resume) { %>
                <option value="<%= resume._id %>">
                  <%= resume.title %> (<%= resume.personalInfo.fullName || 'Untitled' %>)
                </option>
                <% }); %>
              </select>
              <div class="form-help">Your current skills will be extracted from the selected resume</div>
            </div>

            <div class="form-group">
              <label for="targetJobTitle" class="form-label">Target Job Title *</label>
              <input type="text" id="targetJobTitle" name="targetJobTitle" class="form-input" required
                     placeholder="Senior Software Engineer, Data Scientist, Product Manager, etc.">
            </div>

            <div class="form-group">
              <label for="industry" class="form-label">Industry</label>
              <select id="industry" name="industry" class="form-select">
                <option value="Technology">Technology</option>
                <option value="Finance">Finance</option>
                <option value="Healthcare">Healthcare</option>
                <option value="Education">Education</option>
                <option value="Marketing">Marketing</option>
                <option value="Consulting">Consulting</option>
                <option value="Manufacturing">Manufacturing</option>
                <option value="Retail">Retail</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="form-group">
              <label for="targetSkills" class="form-label">Additional Target Skills</label>
              <input type="text" id="targetSkills" name="targetSkills" class="form-input"
                     placeholder="React, Machine Learning, Agile, etc.">
              <div class="form-help">Enter skills required for your target role, separated by commas</div>
            </div>

            <div class="form-group full-width">
              <label for="jobDescription" class="form-label">Job Description (Optional)</label>
              <textarea id="jobDescription" name="jobDescription" class="form-textarea" rows="4"
                        placeholder="Paste a job description to get more accurate skill gap analysis..."></textarea>
              <div class="form-help">Paste a job posting to analyze specific requirements</div>
            </div>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary" id="analyzeBtn">
              <i class="fas fa-chart-line"></i>
              Analyze Skill Gap
            </button>
            <button type="button" class="btn btn-outline" id="clearFormBtn">
              <i class="fas fa-undo"></i>
              Clear Form
            </button>
          </div>
        </form>
      </div>

      <!-- Results Section -->
      <div id="resultsSection" class="results-section" style="display: none;">
        <div class="results-header">
          <h2 class="section-title">
            <i class="fas fa-chart-bar"></i>
            Skill Gap Analysis Results
          </h2>
          <div class="results-actions">
            <button id="saveAnalysisBtn" class="btn btn-outline">
              <i class="fas fa-save"></i>
              Save Analysis
            </button>
            <button id="exportAnalysisBtn" class="btn btn-outline">
              <i class="fas fa-download"></i>
              Export PDF
            </button>
          </div>
        </div>

        <div id="analysisContainer" class="analysis-container">
          <!-- Analysis results will be populated here -->
        </div>
      </div>

      <!-- Loading State -->
      <div id="loadingState" class="loading-state" style="display: none;">
        <div class="loading-spinner">
          <div class="spinner"></div>
        </div>
        <p>Analyzing your skills and identifying gaps...</p>
        <small>This may take a few moments</small>
      </div>

      <!-- Current Skills Preview -->
      <div id="skillsPreview" class="skills-preview" style="display: none;">
        <h3 class="section-title">
          <i class="fas fa-user-check"></i>
          Your Current Skills
        </h3>
        <div id="currentSkillsList" class="skills-list">
          <!-- Current skills will be populated here -->
        </div>
      </div>

      <!-- Learning Resources -->
      <div class="resources-section">
        <h2 class="section-title">
          <i class="fas fa-graduation-cap"></i>
          Popular Learning Resources
        </h2>
        <div class="resources-grid">
          <div class="resource-card">
            <div class="resource-icon">
              <i class="fas fa-laptop-code"></i>
            </div>
            <div class="resource-content">
              <h3>Online Courses</h3>
              <p>Coursera, Udemy, Pluralsight, LinkedIn Learning</p>
              <ul>
                <li>Structured learning paths</li>
                <li>Industry certificates</li>
                <li>Hands-on projects</li>
              </ul>
            </div>
          </div>
          <div class="resource-card">
            <div class="resource-icon">
              <i class="fas fa-code"></i>
            </div>
            <div class="resource-content">
              <h3>Practice Platforms</h3>
              <p>LeetCode, HackerRank, CodeWars, Kaggle</p>
              <ul>
                <li>Coding challenges</li>
                <li>Competitive programming</li>
                <li>Real-world problems</li>
              </ul>
            </div>
          </div>
          <div class="resource-card">
            <div class="resource-icon">
              <i class="fas fa-book"></i>
            </div>
            <div class="resource-content">
              <h3>Documentation & Books</h3>
              <p>Official docs, O'Reilly, Manning Publications</p>
              <ul>
                <li>In-depth knowledge</li>
                <li>Best practices</li>
                <li>Reference materials</li>
              </ul>
            </div>
          </div>
          <div class="resource-card">
            <div class="resource-icon">
              <i class="fas fa-users"></i>
            </div>
            <div class="resource-content">
              <h3>Community & Networking</h3>
              <p>GitHub, Stack Overflow, Discord, Meetups</p>
              <ul>
                <li>Open source contributions</li>
                <li>Peer learning</li>
                <li>Professional networking</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
/* Skill Gap Analyzer Styles */
.analyzer-content {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.analyzer-section, .results-section, .skills-preview, .resources-section {
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  padding: 2rem;
}

.section-title {
  margin: 0 0 1.5rem 0;
  color: #1f2937;
  font-size: 1.25rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.skill-gap-form {
  max-width: none;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.form-group.full-width {
  grid-column: 1 / -1;
}

/* Results Section */
.results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
}

.results-actions {
  display: flex;
  gap: 0.5rem;
}

.analysis-container {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

/* Marketability Score */
.marketability-score {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: white;
  padding: 2rem;
  border-radius: 12px;
  text-align: center;
}

.score-display {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rem;
  margin-bottom: 1rem;
}

.score-circle {
  width: 120px;
  height: 120px;
  border: 8px solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  font-weight: bold;
  position: relative;
}

.score-info h3 {
  margin: 0 0 0.5rem 0;
  font-size: 1.5rem;
}

.score-info p {
  margin: 0;
  opacity: 0.9;
}

/* Analysis Sections */
.analysis-section {
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  overflow: hidden;
}

.analysis-header {
  background: #f9fafb;
  padding: 1rem 1.5rem;
  border-bottom: 1px solid #e5e7eb;
}

.analysis-title {
  margin: 0;
  color: #1f2937;
  font-size: 1.1rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.analysis-content {
  padding: 1.5rem;
}

/* Skills Lists */
.skills-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1rem;
}

.skill-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.75rem;
  background: #f9fafb;
  border: 1px solid #f3f4f6;
  border-radius: 6px;
}

.skill-name {
  font-weight: 500;
  color: #1f2937;
}

.skill-level {
  padding: 0.25rem 0.75rem;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: uppercase;
}

.skill-level.beginner { background: #fee2e2; color: #dc2626; }
.skill-level.intermediate { background: #fef3c7; color: #d97706; }
.skill-level.advanced { background: #d1fae5; color: #047857; }

.skill-gap {
  padding: 0.25rem 0.75rem;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: uppercase;
}

.skill-gap.minor { background: #d1fae5; color: #047857; }
.skill-gap.moderate { background: #fef3c7; color: #d97706; }
.skill-gap.major { background: #fee2e2; color: #dc2626; }

.missing-skill-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 1rem;
  background: #fef2f2;
  border: 1px solid #fecaca;
  border-radius: 6px;
  margin-bottom: 0.75rem;
}

.missing-skill-info {
  flex: 1;
}

.missing-skill-name {
  font-weight: 600;
  color: #dc2626;
  margin: 0 0 0.25rem 0;
}

.missing-skill-meta {
  display: flex;
  gap: 1rem;
  margin-bottom: 0.5rem;
}

.importance, .category, .timeline {
  padding: 0.125rem 0.5rem;
  border-radius: 12px;
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: uppercase;
}

.importance.critical { background: #fee2e2; color: #dc2626; }
.importance.important { background: #fef3c7; color: #d97706; }
.importance.nice-to-have { background: #e0f2fe; color: #0369a1; }

/* Learning Path */
.learning-phases {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1.5rem;
}

.phase-card {
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  padding: 1.5rem;
  background: white;
}

.phase-header {
  margin-bottom: 1rem;
}

.phase-title {
  margin: 0 0 0.5rem 0;
  color: #1f2937;
  font-size: 1.1rem;
  font-weight: 600;
}

.phase-duration {
  color: #6366f1;
  font-weight: 500;
}

.phase-skills {
  margin-bottom: 1rem;
}

.phase-skills h4 {
  margin: 0 0 0.5rem 0;
  color: #374151;
  font-size: 0.875rem;
  font-weight: 600;
}

.phase-skills ul {
  margin: 0;
  padding-left: 1.25rem;
  color: #6b7280;
}

/* Skills Preview */
.skills-list {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.current-skill-tag {
  background: #e0f2fe;
  color: #0369a1;
  padding: 0.25rem 0.75rem;
  border-radius: 20px;
  font-size: 0.875rem;
  font-weight: 500;
}

/* Resources Grid */
.resources-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
}

.resource-card {
  display: flex;
  gap: 1rem;
  padding: 1.5rem;
  background: #f9fafb;
  border: 1px solid #f3f4f6;
  border-radius: 8px;
  transition: all 0.2s ease;
}

.resource-card:hover {
  border-color: #e5e7eb;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.resource-icon {
  width: 48px;
  height: 48px;
  border-radius: 8px;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  color: white;
  flex-shrink: 0;
}

.resource-content h3 {
  margin: 0 0 0.5rem 0;
  color: #1f2937;
  font-size: 1rem;
  font-weight: 600;
}

.resource-content p {
  margin: 0 0 0.75rem 0;
  color: #6b7280;
  font-size: 0.875rem;
}

.resource-content ul {
  margin: 0;
  padding-left: 1.25rem;
  color: #6b7280;
  font-size: 0.75rem;
}

.resource-content ul li {
  margin-bottom: 0.125rem;
}

/* Loading State */
.loading-state {
  text-align: center;
  padding: 4rem 2rem;
  color: #6b7280;
}

.loading-spinner {
  margin-bottom: 1rem;
}

.spinner {
  width: 40px;
  height: 40px;
  border: 4px solid #f3f4f6;
  border-top: 4px solid #6366f1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Responsive Design */
@media (max-width: 768px) {
  .form-grid {
    grid-template-columns: 1fr;
  }
  
  .results-header {
    flex-direction: column;
    gap: 1rem;
    align-items: stretch;
  }
  
  .results-actions {
    justify-content: center;
  }
  
  .skills-grid, .learning-phases, .resources-grid {
    grid-template-columns: 1fr;
  }
  
  .score-display {
    flex-direction: column;
    gap: 1rem;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('skillGapForm');
  const resumeSelect = document.getElementById('resumeId');
  const analyzeBtn = document.getElementById('analyzeBtn');
  const clearFormBtn = document.getElementById('clearFormBtn');
  const loadingState = document.getElementById('loadingState');
  const resultsSection = document.getElementById('resultsSection');
  const analysisContainer = document.getElementById('analysisContainer');
  const skillsPreview = document.getElementById('skillsPreview');
  const currentSkillsList = document.getElementById('currentSkillsList');

  // Resume selection handler
  resumeSelect.addEventListener('change', function() {
    if (this.value) {
      // Show current skills preview (would fetch from server in real implementation)
      showSkillsPreview();
    } else {
      skillsPreview.style.display = 'none';
    }
  });

  // Form submission
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const formData = new FormData(form);
    
    if (!formData.get('targetJobTitle').trim()) {
      alert('Please enter a target job title.');
      return;
    }
    
    // Show loading state
    loadingState.style.display = 'block';
    resultsSection.style.display = 'none';
    analyzeBtn.disabled = true;
    
    try {
      const response = await fetch('/skill-gap/analyze', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          resumeId: formData.get('resumeId') || null,
          targetJobTitle: formData.get('targetJobTitle'),
          industry: formData.get('industry'),
          targetSkills: formData.get('targetSkills'),
          jobDescription: formData.get('jobDescription')
        })
      });
      
      const data = await response.json();
      
      if (data.success) {
        displayAnalysis(data.analysis, data.metadata);
      } else {
        alert('Error analyzing skills: ' + data.error);
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Failed to analyze skills. Please try again.');
    } finally {
      loadingState.style.display = 'none';
      analyzeBtn.disabled = false;
    }
  });

  // Clear form
  clearFormBtn.addEventListener('click', function() {
    form.reset();
    resultsSection.style.display = 'none';
    skillsPreview.style.display = 'none';
  });

  function showSkillsPreview() {
    // This would fetch actual skills from the selected resume
    // For now, showing placeholder
    const sampleSkills = ['JavaScript', 'React', 'Node.js', 'Python', 'SQL', 'Git'];
    
    currentSkillsList.innerHTML = sampleSkills.map(skill => 
      `<span class="current-skill-tag">${skill}</span>`
    ).join('');
    
    skillsPreview.style.display = 'block';
  }

  function displayAnalysis(analysis, metadata) {
    let html = '';
    
    // Marketability Score
    if (analysis.marketability) {
      html += createMarketabilitySection(analysis.marketability);
    }
    
    // Matching Skills
    if (analysis.analysis && analysis.analysis.matchingSkills) {
      html += createMatchingSkillsSection(analysis.analysis.matchingSkills);
    }
    
    // Missing Skills
    if (analysis.analysis && analysis.analysis.missingSkills) {
      html += createMissingSkillsSection(analysis.analysis.missingSkills);
    }
    
    // Learning Path
    if (analysis.learningPath) {
      html += createLearningPathSection(analysis.learningPath);
    }
    
    // Recommendations
    if (analysis.recommendations) {
      html += createRecommendationsSection(analysis.recommendations);
    }
    
    analysisContainer.innerHTML = html;
    resultsSection.style.display = 'block';
    
    // Scroll to results
    resultsSection.scrollIntoView({ behavior: 'smooth' });
  }

  function createMarketabilitySection(marketability) {
    return `
      <div class="marketability-score">
        <div class="score-display">
          <div class="score-circle">
            <span>${marketability.currentScore}/100</span>
          </div>
          <div class="score-info">
            <h3>Current Marketability</h3>
            <p>Target Score: ${marketability.targetScore}</p>
            <p>Time to Market Ready: ${marketability.timeToMarketReady}</p>
          </div>
        </div>
        <div class="key-improvements">
          <h4>Key Improvements Needed:</h4>
          <ul>
            ${marketability.keyImprovements.map(improvement => `<li>${improvement}</li>`).join('')}
          </ul>
        </div>
      </div>
    `;
  }

  function createMatchingSkillsSection(matchingSkills) {
    return `
      <div class="analysis-section">
        <div class="analysis-header">
          <h3 class="analysis-title">
            <i class="fas fa-check-circle"></i>
            Skills You Already Have
          </h3>
        </div>
        <div class="analysis-content">
          <div class="skills-grid">
            ${matchingSkills.map(skill => `
              <div class="skill-item">
                <span class="skill-name">${skill.skill}</span>
                <span class="skill-gap ${skill.gap}">${skill.gap} gap</span>
              </div>
            `).join('')}
          </div>
        </div>
      </div>
    `;
  }

  function createMissingSkillsSection(missingSkills) {
    return `
      <div class="analysis-section">
        <div class="analysis-header">
          <h3 class="analysis-title">
            <i class="fas fa-exclamation-triangle"></i>
            Skills You Need to Develop
          </h3>
        </div>
        <div class="analysis-content">
          ${missingSkills.map(skill => `
            <div class="missing-skill-item">
              <div class="missing-skill-info">
                <h4 class="missing-skill-name">${skill.skill}</h4>
                <div class="missing-skill-meta">
                  <span class="importance ${skill.importance.toLowerCase()}">${skill.importance}</span>
                  <span class="category">${skill.category}</span>
                  <span class="timeline">${skill.estimatedLearningTime}</span>
                </div>
              </div>
            </div>
          `).join('')}
        </div>
      </div>
    `;
  }

  function createLearningPathSection(learningPath) {
    return `
      <div class="analysis-section">
        <div class="analysis-header">
          <h3 class="analysis-title">
            <i class="fas fa-route"></i>
            Recommended Learning Path
          </h3>
        </div>
        <div class="analysis-content">
          <div class="learning-phases">
            ${Object.entries(learningPath).map(([phase, data]) => `
              <div class="phase-card">
                <div class="phase-header">
                  <h4 class="phase-title">${data.title}</h4>
                  <p class="phase-duration">${data.duration}</p>
                </div>
                <div class="phase-skills">
                  <h4>Skills to Focus On:</h4>
                  <ul>
                    ${data.skills.map(skill => `<li>${skill}</li>`).join('')}
                  </ul>
                </div>
                <div class="phase-projects">
                  <h4>Recommended Projects:</h4>
                  <ul>
                    ${data.projects.map(project => `<li>${project}</li>`).join('')}
                  </ul>
                </div>
              </div>
            `).join('')}
          </div>
        </div>
      </div>
    `;
  }

  function createRecommendationsSection(recommendations) {
    return `
      <div class="analysis-section">
        <div class="analysis-header">
          <h3 class="analysis-title">
            <i class="fas fa-lightbulb"></i>
            Action Plan & Recommendations
          </h3>
        </div>
        <div class="analysis-content">
          <div class="recommendations-grid">
            <div class="recommendation-category">
              <h4>Immediate Actions (1-2 months)</h4>
              <ul>
                ${recommendations.immediate.map(rec => `
                  <li><strong>${rec.skill}:</strong> ${rec.action}</li>
                `).join('')}
              </ul>
            </div>
            <div class="recommendation-category">
              <h4>Intermediate Goals (3-6 months)</h4>
              <ul>
                ${recommendations.intermediate.map(rec => `
                  <li><strong>${rec.skill}:</strong> ${rec.action}</li>
                `).join('')}
              </ul>
            </div>
            <div class="recommendation-category">
              <h4>Long-term Objectives (6+ months)</h4>
              <ul>
                ${recommendations.advanced.map(rec => `
                  <li><strong>${rec.skill}:</strong> ${rec.action}</li>
                `).join('')}
              </ul>
            </div>
          </div>
        </div>
      </div>
    `;
  }
});
</script>

<%- include('../partials/footer') %>