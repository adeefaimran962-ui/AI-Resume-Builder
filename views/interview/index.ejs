<%- include('../partials/header') %>

<div class="dashboard-container">
  <div class="dashboard-main">
    <div class="dashboard-header">
      <div class="dashboard-title-section">
        <h1 class="dashboard-title">
          <i class="fas fa-question-circle"></i>
          Interview Questions Generator
        </h1>
        <p class="dashboard-subtitle">Prepare for interviews with AI-generated questions tailored to your profile</p>
      </div>
    </div>

    <div class="interview-content">
      <!-- Generator Form -->
      <div class="generator-section">
        <h2 class="section-title">
          <i class="fas fa-magic"></i>
          Generate Interview Questions
        </h2>
        
        <form id="interviewForm" class="interview-form">
          <div class="form-grid">
            <div class="form-group">
              <label for="resumeId" class="form-label">Select Resume (Optional)</label>
              <select id="resumeId" name="resumeId" class="form-select">
                <option value="">Choose a resume to analyze...</option>
                <% resumes.forEach(function(resume) { %>
                <option value="<%= resume._id %>">
                  <%= resume.title %> (<%= resume.personalInfo.fullName || 'Untitled' %>)
                </option>
                <% }); %>
              </select>
              <div class="form-help">Select a resume to get personalized questions based on your experience</div>
            </div>

            <div class="form-group">
              <label for="jobTitle" class="form-label">Target Job Title *</label>
              <input type="text" id="jobTitle" name="jobTitle" class="form-input" required
                     placeholder="Software Engineer, Product Manager, etc.">
            </div>

            <div class="form-group">
              <label for="experienceLevel" class="form-label">Experience Level</label>
              <select id="experienceLevel" name="experienceLevel" class="form-select">
                <option value="Entry-level">Entry-level (0-2 years)</option>
                <option value="Mid-level" selected>Mid-level (2-5 years)</option>
                <option value="Senior-level">Senior-level (5-8 years)</option>
                <option value="Lead/Principal">Lead/Principal (8+ years)</option>
                <option value="Executive">Executive/C-level</option>
              </select>
            </div>

            <div class="form-group">
              <label for="customSkills" class="form-label">Additional Skills to Focus On</label>
              <input type="text" id="customSkills" name="customSkills" class="form-input"
                     placeholder="JavaScript, Leadership, Project Management, etc.">
              <div class="form-help">Enter skills separated by commas</div>
            </div>

            <div class="form-group full-width">
              <label class="form-label">Question Types</label>
              <div class="checkbox-group">
                <label class="checkbox-item">
                  <input type="checkbox" name="questionTypes" value="technical" checked>
                  <span class="checkmark"></span>
                  Technical Questions
                  <small>Role-specific technical skills and knowledge</small>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="questionTypes" value="behavioral" checked>
                  <span class="checkmark"></span>
                  Behavioral Questions
                  <small>STAR method questions about past experiences</small>
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="questionTypes" value="hr" checked>
                  <span class="checkmark"></span>
                  HR/General Questions
                  <small>Company fit, motivation, and career goals</small>
                </label>
              </div>
            </div>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary" id="generateBtn">
              <i class="fas fa-magic"></i>
              Generate Interview Questions
            </button>
            <button type="button" class="btn btn-outline" id="clearBtn">
              <i class="fas fa-undo"></i>
              Clear Form
            </button>
          </div>
        </form>
      </div>

      <!-- Results Section -->
      <div id="resultsSection" class="results-section" style="display: none;">
        <div class="results-header">
          <h2 class="section-title">
            <i class="fas fa-list-alt"></i>
            Generated Interview Questions
          </h2>
          <div class="results-actions">
            <button id="printBtn" class="btn btn-outline">
              <i class="fas fa-print"></i>
              Print Questions
            </button>
            <button id="exportBtn" class="btn btn-outline">
              <i class="fas fa-download"></i>
              Export as PDF
            </button>
          </div>
        </div>

        <div id="questionsContainer" class="questions-container">
          <!-- Questions will be populated here -->
        </div>
      </div>

      <!-- Loading State -->
      <div id="loadingState" class="loading-state" style="display: none;">
        <div class="loading-spinner">
          <div class="spinner"></div>
        </div>
        <p>Generating personalized interview questions...</p>
        <small>This may take a few moments</small>
      </div>

      <!-- Tips Section -->
      <div class="tips-section">
        <h2 class="section-title">
          <i class="fas fa-lightbulb"></i>
          Interview Preparation Tips
        </h2>
        <div class="tips-grid">
          <div class="tip-card">
            <div class="tip-icon">
              <i class="fas fa-star"></i>
            </div>
            <div class="tip-content">
              <h3>STAR Method</h3>
              <p>Structure behavioral answers with Situation, Task, Action, Result for clear and impactful responses.</p>
            </div>
          </div>
          <div class="tip-card">
            <div class="tip-icon">
              <i class="fas fa-search"></i>
            </div>
            <div class="tip-content">
              <h3>Research the Company</h3>
              <p>Study the company's mission, values, recent news, and the specific role requirements before the interview.</p>
            </div>
          </div>
          <div class="tip-card">
            <div class="tip-icon">
              <i class="fas fa-comments"></i>
            </div>
            <div class="tip-content">
              <h3>Practice Out Loud</h3>
              <p>Rehearse your answers verbally to improve fluency and identify areas that need more preparation.</p>
            </div>
          </div>
          <div class="tip-card">
            <div class="tip-icon">
              <i class="fas fa-question"></i>
            </div>
            <div class="tip-content">
              <h3>Prepare Questions</h3>
              <p>Have thoughtful questions ready about the role, team, company culture, and growth opportunities.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
/* Interview Questions Styles */
.interview-content {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.badge-difficulty {
  display: inline-flex;
  align-items: center;
  font-size: 11px;
  padding: 4px 8px;
  border-radius: 4px;
  font-weight: 600;
  text-transform: uppercase;
}
.badge-easy {
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
  border: 1px solid rgba(16, 185, 129, 0.2);
}
.badge-medium {
  background: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
  border: 1px solid rgba(245, 158, 11, 0.2);
}
.badge-hard {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
  border: 1px solid rgba(239, 68, 68, 0.2);
}

[data-theme="dark"] .generator-section,
[data-theme="dark"] .results-section,
[data-theme="dark"] .tips-section {
  background: #1f2937;
  border-color: #374151;
}
[data-theme="dark"] .section-title {
  color: #f9fafb;
}
[data-theme="dark"] .checkbox-item {
  border-color: #374151;
}
[data-theme="dark"] .checkbox-item:hover {
  background: #374151;
}
[data-theme="dark"] .category-header {
  background: #374151;
  border-color: #4b5563;
}
[data-theme="dark"] .category-title {
  color: #f9fafb;
}
[data-theme="dark"] .question-text {
  color: #f9fafb;
}
[data-theme="dark"] .question-details {
  background: #374151;
}
[data-theme="dark"] .question-section h4 {
  color: #e5e7eb;
}
[data-theme="dark"] .question-section p,
[data-theme="dark"] .question-section ul {
  color: #9ca3af;
}
[data-theme="dark"] .tip-card {
  background: #374151;
  border-color: #4b5563;
}
[data-theme="dark"] .tip-content h3 {
  color: #f9fafb;
}
[data-theme="dark"] .tip-content p {
  color: #9ca3af;
}

.generator-section, .results-section, .tips-section {
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  padding: 2rem;
}

.section-title {
  margin: 0 0 1.5rem 0;
  color: #1f2937;
  font-size: 1.25rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.interview-form {
  max-width: none;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.form-group.full-width {
  grid-column: 1 / -1;
}

.checkbox-group {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.checkbox-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  cursor: pointer;
  padding: 0.75rem;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  transition: all 0.2s ease;
}

.checkbox-item:hover {
  border-color: #6366f1;
  background: #f8fafc;
}

.checkbox-item input[type="checkbox"] {
  display: none;
}

.checkmark {
  width: 20px;
  height: 20px;
  border: 2px solid #d1d5db;
  border-radius: 4px;
  position: relative;
  transition: all 0.2s ease;
  flex-shrink: 0;
  margin-top: 2px;
}

.checkbox-item input[type="checkbox"]:checked + .checkmark {
  background: #6366f1;
  border-color: #6366f1;
}

.checkbox-item input[type="checkbox"]:checked + .checkmark::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: white;
  font-weight: bold;
  font-size: 0.75rem;
}

.checkbox-item div {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.checkbox-item small {
  color: #6b7280;
  font-size: 0.75rem;
}

/* Results Section */
.results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
}

.results-actions {
  display: flex;
  gap: 0.5rem;
}

.questions-container {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.question-category {
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  overflow: hidden;
}

.category-header {
  background: #f9fafb;
  padding: 1rem 1.5rem;
  border-bottom: 1px solid #e5e7eb;
}

.category-title {
  margin: 0;
  color: #1f2937;
  font-size: 1.1rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.question-list {
  padding: 0;
  margin: 0;
  list-style: none;
}

.question-item {
  padding: 1.5rem;
  border-bottom: 1px solid #f3f4f6;
}

.question-item:last-child {
  border-bottom: none;
}

.question-text {
  margin: 0 0 1rem 0;
  color: #1f2937;
  font-size: 1rem;
  font-weight: 500;
  line-height: 1.5;
}

.question-details {
  background: #f9fafb;
  border-radius: 6px;
  padding: 1rem;
}

.question-section {
  margin-bottom: 1rem;
}

.question-section:last-child {
  margin-bottom: 0;
}

.question-section h4 {
  margin: 0 0 0.5rem 0;
  color: #374151;
  font-size: 0.875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.question-section p {
  margin: 0;
  color: #6b7280;
  font-size: 0.875rem;
  line-height: 1.5;
}

.question-section ul {
  margin: 0;
  padding-left: 1.5rem;
  color: #6b7280;
  font-size: 0.875rem;
}

.question-section ul li {
  margin-bottom: 0.25rem;
}

/* Loading State */
.loading-state {
  text-align: center;
  padding: 4rem 2rem;
  color: #6b7280;
}

.loading-spinner {
  margin-bottom: 1rem;
}

.spinner {
  width: 40px;
  height: 40px;
  border: 4px solid #f3f4f6;
  border-top: 4px solid #6366f1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Tips Section */
.tips-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
}

.tip-card {
  display: flex;
  gap: 1rem;
  padding: 1.5rem;
  background: #f9fafb;
  border: 1px solid #f3f4f6;
  border-radius: 8px;
  transition: all 0.2s ease;
}

.tip-card:hover {
  border-color: #e5e7eb;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.tip-icon {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
  color: white;
  flex-shrink: 0;
}

.tip-content h3 {
  margin: 0 0 0.5rem 0;
  color: #1f2937;
  font-size: 1rem;
  font-weight: 600;
}

.tip-content p {
  margin: 0;
  color: #6b7280;
  font-size: 0.875rem;
  line-height: 1.5;
}

/* Responsive Design */
@media (max-width: 768px) {
  .form-grid {
    grid-template-columns: 1fr;
  }
  
  .results-header {
    flex-direction: column;
    gap: 1rem;
    align-items: stretch;
  }
  
  .results-actions {
    justify-content: center;
  }
  
  .tips-grid {
    grid-template-columns: 1fr;
  }
  
  .checkbox-group {
    gap: 0.75rem;
  }
}

/* Print Styles */
@media print {
  .dashboard-header,
  .generator-section,
  .tips-section,
  .results-actions,
  .btn {
    display: none !important;
  }
  
  .questions-container {
    page-break-inside: avoid;
  }
  
  .question-item {
    page-break-inside: avoid;
    margin-bottom: 1rem;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.getElementById('interviewForm');
  const generateBtn = document.getElementById('generateBtn');
  const clearBtn = document.getElementById('clearBtn');
  const loadingState = document.getElementById('loadingState');
  const resultsSection = document.getElementById('resultsSection');
  const questionsContainer = document.getElementById('questionsContainer');
  const printBtn = document.getElementById('printBtn');
  const exportBtn = document.getElementById('exportBtn');

  // Form submission
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const formData = new FormData(form);
    const questionTypes = Array.from(formData.getAll('questionTypes'));
    
    if (questionTypes.length === 0) {
      alert('Please select at least one question type.');
      return;
    }
    
    if (!formData.get('jobTitle').trim()) {
      alert('Please enter a job title.');
      return;
    }
    
    // Show loading state
    loadingState.style.display = 'block';
    resultsSection.style.display = 'none';
    generateBtn.disabled = true;
    
    try {
      const response = await fetch('/interview/generate', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          resumeId: formData.get('resumeId') || null,
          jobTitle: formData.get('jobTitle'),
          experienceLevel: formData.get('experienceLevel'),
          customSkills: formData.get('customSkills'),
          questionTypes: questionTypes
        })
      });
      
      const data = await response.json();
      
      if (data.success) {
        displayQuestions(data.questions, data.metadata);
      } else {
        alert('Error generating questions: ' + data.error);
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Failed to generate questions. Please try again.');
    } finally {
      loadingState.style.display = 'none';
      generateBtn.disabled = false;
    }
  });

  // Clear form
  clearBtn.addEventListener('click', function() {
    form.reset();
    resultsSection.style.display = 'none';
  });

  // Print functionality
  printBtn.addEventListener('click', function() {
    window.print();
  });

  // Export functionality (placeholder)
  exportBtn.addEventListener('click', function() {
    // This would need to be implemented with a PDF generation library
    alert('PDF export functionality would be implemented here.');
  });

  function displayQuestions(questions, metadata) {
    let html = '';
    
    // Add metadata header
    html += `
      <div class="questions-metadata">
        <h3>Interview Questions for: ${metadata.jobTitle}</h3>
        <p>Experience Level: ${metadata.experienceLevel}</p>
        <p>Generated on: ${new Date(metadata.generatedAt).toLocaleDateString()}</p>
      </div>
    `;
    
    // Technical Questions
    if (questions.technical && questions.technical.length > 0) {
      html += createQuestionCategory('Technical Questions', 'fas fa-code', questions.technical);
    }
    
    // Behavioral Questions
    if (questions.behavioral && questions.behavioral.length > 0) {
      html += createQuestionCategory('Behavioral Questions', 'fas fa-users', questions.behavioral);
    }
    
    // HR Questions
    if (questions.hr && questions.hr.length > 0) {
      html += createQuestionCategory('HR & General Questions', 'fas fa-handshake', questions.hr);
    }
    
    questionsContainer.innerHTML = html;
    resultsSection.style.display = 'block';
    
    // Scroll to results
    resultsSection.scrollIntoView({ behavior: 'smooth' });
  }

  function createQuestionCategory(title, icon, questions) {
    let html = `
      <div class="question-category">
        <div class="category-header">
          <h3 class="category-title">
            <i class="${icon}"></i>
            ${title}
          </h3>
        </div>
        <ul class="question-list">
    `;
    
    questions.forEach((q, index) => {
      const difficultyLower = q.difficulty ? q.difficulty.toLowerCase() : 'medium';
      html += `
        <li class="question-item">
          <h4 class="question-text">Q${index + 1}: ${q.question}</h4>
          
          <div style="display:flex; gap:8px; margin-bottom:14px; align-items:center; flex-wrap:wrap;">
            <span class="badge-difficulty badge-${difficultyLower}">
              ${q.difficulty || 'Medium'}
            </span>
            <span style="font-size: 11px; padding: 4px 8px; border-radius: 4px; font-weight: 500; background: var(--bg-3); color: var(--muted); border: 1px solid var(--border); display: inline-flex; align-items: center; gap: 4px;">
              <i class="far fa-clock"></i> ${q.time || '3 mins'}
            </span>
          </div>

          <div class="question-details">
            <div class="question-section">
              <h4>What They're Looking For:</h4>
              <ul>
                ${Array.isArray(q.lookingFor) ? q.lookingFor.map(point => `<li>${point}</li>`).join('') : `<li>${q.lookingFor}</li>`}
              </ul>
            </div>
            <div class="question-section">
              <h4>How to Approach:</h4>
              <p>${q.approachTips}</p>
            </div>
            <div class="question-section">
              <h4>Common Mistakes to Avoid:</h4>
              <ul>
                ${Array.isArray(q.avoidMistakes) ? q.avoidMistakes.map(mistake => `<li>${mistake}</li>`).join('') : `<li>${q.avoidMistakes}</li>`}
              </ul>
            </div>
          </div>
        </li>
      `;
    });
    
    html += '</ul></div>';
    return html;
  }
});
</script>

<%- include('../partials/footer') %>