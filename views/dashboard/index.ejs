
<%- include("../partials/header") %>

<style>
/* Modern Dashboard Styles */
:root {
  --bg-primary: #ffffff;
  --bg-secondary: #f8fafc;
  --bg-tertiary: #f1f5f9;
  --border-color: #e2e8f0;
  --text-primary: #0f172a;
  --text-secondary: #475569;
  --text-tertiary: #94a3b8;
  --primary: #6366f1;
  --primary-hover: #4f46e5;
  --success: #10b981;
  --warning: #f59e0b;
  --danger: #ef4444;
  --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
  --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
  --radius: 12px;
  --radius-sm: 8px;
  --font-family: 'Inter', system-ui, -apple-system, sans-serif;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: var(--font-family);
  background: var(--bg-secondary);
  color: var(--text-primary);
  line-height: 1.5;
}

.dashboard-layout {
  display: flex;
  min-height: 100vh;
}

/* Sidebar */
.sidebar {
  width: 260px;
  background: var(--bg-primary);
  border-right: 1px solid var(--border-color);
  display: flex;
  flex-direction: column;
  position: fixed;
  height: 100vh;
  left: 0;
  top: 0;
  z-index: 50;
  transition: width 0.3s ease;
}

.sidebar.collapsed {
  width: 70px;
}

.sidebar-logo {
  padding: 24px;
  border-bottom: 1px solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sidebar-logo a {
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
  color: var(--text-primary);
  font-weight: 700;
  font-size: 1.25rem;
}

.sidebar-logo a span {
  white-space: nowrap;
}

.sidebar.collapsed .sidebar-logo a span:last-child {
  display: none;
}

.sidebar-collapse-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 8px;
  border-radius: var(--radius-sm);
  color: var(--text-secondary);
  transition: all 0.2s;
}

.sidebar-collapse-btn:hover {
  background: var(--bg-tertiary);
  color: var(--text-primary);
}

.sidebar-nav {
  flex: 1;
  padding: 16px;
  overflow-y: auto;
}

.sidebar-nav-section {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 8px;
  margin-top: 16px;
}

.sidebar.collapsed .sidebar-nav-section {
  display: none;
}

.sidebar-nav-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border-radius: var(--radius-sm);
  text-decoration: none;
  color: var(--text-secondary);
  transition: all 0.2s;
  margin-bottom: 4px;
  white-space: nowrap;
}

.sidebar-nav-item:hover {
  background: var(--bg-tertiary);
  color: var(--text-primary);
}

.sidebar-nav-item.active {
  background: var(--primary);
  color: white;
}

.sidebar-nav-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  flex-shrink: 0;
}

.sidebar-nav-text {
  flex: 1;
}

.sidebar.collapsed .sidebar-nav-text {
  display: none;
}

.sidebar-badge {
  background: var(--danger);
  color: white;
  font-size: 0.75rem;
  padding: 2px 8px;
  border-radius: 9999px;
  font-weight: 600;
}

.sidebar.collapsed .sidebar-badge {
  position: absolute;
  top: 8px;
  right: 8px;
}

.sidebar-footer {
  padding: 16px;
  border-top: 1px solid var(--border-color);
}

.sidebar-user {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  background: var(--bg-tertiary);
  border-radius: var(--radius-sm);
  margin-bottom: 12px;
}

.sidebar-user-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--primary);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 0.875rem;
  flex-shrink: 0;
}

.sidebar-user-name {
  font-weight: 600;
  font-size: 0.875rem;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sidebar-user-email {
  font-size: 0.75rem;
  color: var(--text-tertiary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sidebar.collapsed .sidebar-user-name,
.sidebar.collapsed .sidebar-user-email {
  display: none;
}

.sidebar-logout {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px;
  border-radius: var(--radius-sm);
  text-decoration: none;
  color: var(--text-secondary);
  font-size: 0.875rem;
  transition: all 0.2s;
}

.sidebar-logout:hover {
  background: var(--bg-tertiary);
  color: var(--danger);
}

.sidebar.collapsed .sidebar-logout {
  justify-content: center;
}

.sidebar.collapsed .sidebar-logout span {
  display: none;
}

/* Main Content */
.dashboard-main {
  flex: 1;
  margin-left: 260px;
  display: flex;
  flex-direction: column;
  transition: margin-left 0.3s ease;
}

.sidebar.collapsed + .dashboard-main {
  margin-left: 70px;
}

/* Top Bar */
.topbar {
  background: var(--bg-primary);
  border-bottom: 1px solid var(--border-color);
  padding: 16px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 40;
}

.topbar-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--text-primary);
}

.topbar-actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.sidebar-toggle-btn {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  padding: 8px;
  border-radius: var(--radius-sm);
  font-size: 1.25rem;
  color: var(--text-secondary);
}

.nav-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--primary);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  text-decoration: none;
}

/* Page Content */
.page-content {
  padding: 24px;
  max-width: 1400px;
  margin: 0 auto;
  width: 100%;
}

/* Hero Section */
.hero {
  background: linear-gradient(135deg, var(--primary) 0%, #8b5cf6 100%);
  border-radius: var(--radius);
  padding: 48px;
  color: white;
  margin-bottom: 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 48px;
}

.hero-content {
  flex: 1;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255, 255, 255, 0.2);
  padding: 8px 16px;
  border-radius: 9999px;
  font-size: 0.875rem;
  font-weight: 500;
  margin-bottom: 16px;
}

.hero-title {
  font-size: 2.5rem;
  font-weight: 800;
  margin-bottom: 16px;
  line-height: 1.2;
}

.hero-subtitle {
  font-size: 1.125rem;
  opacity: 0.9;
  margin-bottom: 24px;
  max-width: 500px;
}

.hero-actions {
  display: flex;
  gap: 12px;
}

.hero-visual {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.hero-illustration {
  width: 300px;
  height: 300px;
  position: relative;
}

.hero-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.hero-circle-1 {
  width: 200px;
  height: 200px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.hero-circle-2 {
  width: 150px;
  height: 150px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.hero-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 4rem;
  color: white;
}

/* Buttons */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  border-radius: var(--radius-sm);
  font-weight: 600;
  font-size: 0.875rem;
  text-decoration: none;
  cursor: pointer;
  border: none;
  transition: all 0.2s;
  font-family: var(--font-family);
}

.btn-primary {
  background: var(--primary);
  color: white;
}

.btn-primary:hover {
  background: var(--primary-hover);
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.btn-outline {
  background: transparent;
  border: 2px solid var(--border-color);
  color: var(--text-primary);
}

.btn-outline:hover {
  border-color: var(--primary);
  color: var(--primary);
}

.btn-sm {
  padding: 8px 16px;
  font-size: 0.8125rem;
}

.btn-lg {
  padding: 16px 32px;
  font-size: 1rem;
}

/* Stats Grid */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 24px;
  margin-bottom: 32px;
}

.stat-card {
  background: var(--bg-primary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius);
  padding: 24px;
  display: flex;
  align-items: center;
  gap: 16px;
  transition: all 0.2s;
}

.stat-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

.stat-icon {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 1.5rem;
}

.stat-value {
  font-size: 2rem;
  font-weight: 800;
  color: var(--text-primary);
}

.stat-label {
  font-size: 0.875rem;
  color: var(--text-secondary);
  margin-top: 4px;
}

/* Section Header */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
}

.section-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text-primary);
}

.section-subtitle {
  font-size: 0.875rem;
  color: var(--text-secondary);
  margin-top: 4px;
}

/* Resume Grid */
.resume-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 24px;
  margin-bottom: 32px;
}

.resume-card {
  background: var(--bg-primary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius);
  overflow: hidden;
  transition: all 0.2s;
}

.resume-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

.resume-card-header {
  padding: 16px;
  border-bottom: 1px solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.resume-template {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-secondary);
}

.resume-card-body {
  padding: 16px;
}

.resume-card-title {
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8px;
}

.resume-card-meta {
  font-size: 0.875rem;
  color: var(--text-secondary);
  margin-bottom: 16px;
}

.resume-card-stats {
  display: flex;
  gap: 16px;
}

.resume-stat {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  color: var(--text-secondary);
}

.resume-card-footer {
  padding: 16px;
  border-top: 1px solid var(--border-color);
  display: flex;
  gap: 8px;
}

/* Empty State */
.empty-state {
  background: var(--bg-primary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius);
  padding: 64px 32px;
  text-align: center;
}

.empty-state-icon {
  font-size: 4rem;
  margin-bottom: 24px;
}

.empty-state-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12px;
}

.empty-state-description {
  font-size: 1rem;
  color: var(--text-secondary);
  margin-bottom: 24px;
  max-width: 400px;
  margin-left: auto;
  margin-right: auto;
}

/* Form Controls */
.form-control {
  padding: 12px 16px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  font-size: 0.875rem;
  font-family: var(--font-family);
  background: var(--bg-primary);
  color: var(--text-primary);
  transition: all 0.2s;
}

.form-control:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
}

/* Responsive */
@media (max-width: 1024px) {
  .sidebar {
    transform: translateX(-100%);
  }
  
  .sidebar.open {
    transform: translateX(0);
  }
  
  .dashboard-main {
    margin-left: 0;
  }
  
  .sidebar-toggle-btn {
    display: block;
  }
  
  .hero {
    flex-direction: column;
    text-align: center;
  }
  
  .hero-visual {
    display: none;
  }
}

@media (max-width: 768px) {
  .stats-grid {
    grid-template-columns: 1fr;
  }
  
  .resume-grid {
    grid-template-columns: 1fr;
  }
  
  .hero-title {
    font-size: 2rem;
  }
  
  .topbar-actions {
    gap: 8px;
  }
  
  .btn {
    padding: 10px 16px;
  }
}
</style>

<div class="dashboard-layout">
  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <a href="/">
        <i data-lucide="zap" style="width: 24px; height: 24px;"></i>
        <span>ResumeAI</span>
      </a>
      <button class="sidebar-collapse-btn" id="sidebarCollapse">
        <i data-lucide="chevron-left" style="width: 20px; height: 20px;"></i>
      </button>
    </div>

    <nav class="sidebar-nav">
      <div class="sidebar-nav-section">Main</div>
      <a href="/dashboard" class="sidebar-nav-item active">
        <i data-lucide="layout-dashboard" style="width: 20px; height: 20px;"></i>
        <span>Dashboard</span>
      </a>
      <a href="/resume/new" class="sidebar-nav-item">
        <i data-lucide="file-plus" style="width: 20px; height: 20px;"></i>
        <span>New Resume</span>
      </a>

      <div class="sidebar-nav-section">Documents</div>
      <a href="/dashboard" class="sidebar-nav-item">
        <i data-lucide="folder-open" style="width: 20px; height: 20px;"></i>
        <span>My Resumes</span>
      </a>
      <a href="/cover-letter/new" class="sidebar-nav-item">
        <i data-lucide="mail" style="width: 20px; height: 20px;"></i>
        <span>Cover Letters</span>
      </a>
      <a href="/certificates" class="sidebar-nav-item">
        <i data-lucide="award" style="width: 20px; height: 20px;"></i>
        <span>Certificates</span>
      </a>
      <a href="/dashboard/trash" class="sidebar-nav-item">
        <i data-lucide="trash-2" style="width: 20px; height: 20px;"></i>
        <span>Trash</span>
        <% if (typeof trashCount !== 'undefined' && trashCount > 0) { %>
          <span class="sidebar-badge"><%= trashCount %></span>
        <% } %>
      </a>

      <div class="sidebar-nav-section">Career Tools</div>
      <a href="/jobs" class="sidebar-nav-item">
        <i data-lucide="briefcase" style="width: 20px; height: 20px;"></i>
        <span>Job Tracker</span>
      </a>
      <a href="/interview" class="sidebar-nav-item">
        <i data-lucide="message-square" style="width: 20px; height: 20px;"></i>
        <span>Interview Prep</span>
      </a>
      <a href="/skill-gap" class="sidebar-nav-item">
        <i data-lucide="brain" style="width: 20px; height: 20px;"></i>
        <span>Skill Analysis</span>
      </a>
      <a href="/career-roadmap" class="sidebar-nav-item">
        <i data-lucide="compass" style="width: 20px; height: 20px;"></i>
        <span>Career Roadmap</span>
      </a>

      <div class="sidebar-nav-section">AI Tools</div>
      <a href="/resume/ats-checker" class="sidebar-nav-item">
        <i data-lucide="crosshair" style="width: 20px; height: 20px;"></i>
        <span>ATS Checker</span>
      </a>
      <a href="/resume/new" class="sidebar-nav-item">
        <i data-lucide="sparkles" style="width: 20px; height: 20px;"></i>
        <span>AI Resume</span>
      </a>
      <a href="/cover-letter/new" class="sidebar-nav-item">
        <i data-lucide="pen-tool" style="width: 20px; height: 20px;"></i>
        <span>AI Cover Letter</span>
      </a>

      <div class="sidebar-nav-section">Account</div>
      <a href="/dashboard/profile" class="sidebar-nav-item">
        <i data-lucide="user" style="width: 20px; height: 20px;"></i>
        <span>Profile</span>
      </a>
      <a href="/dashboard/settings" class="sidebar-nav-item">
        <i data-lucide="settings" style="width: 20px; height: 20px;"></i>
        <span>Settings</span>
      </a>
    </nav>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <% if (currentUser.avatar) { %>
          <img src="<%= currentUser.avatar %>" alt="Avatar" class="sidebar-user-avatar">
        <% } else { %>
          <div class="sidebar-user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></div>
        <% } %>
        <div>
          <div class="sidebar-user-name"><%= currentUser.name %></div>
          <div class="sidebar-user-email"><%= currentUser.email %></div>
        </div>
      </div>
      <a href="/auth/logout" class="sidebar-logout">
        <i data-lucide="log-out" style="width: 20px; height: 20px;"></i>
        <span>Logout</span>
      </a>
    </div>
  </aside>

  <!-- Main Content -->
  <div class="dashboard-main">
    <!-- Top Bar -->
    <header class="topbar">
      <div style="display: flex; align-items: center; gap: 16px;">
        <button class="sidebar-toggle-btn" id="sidebarToggle">
          <i data-lucide="menu" style="width: 24px; height: 24px;"></i>
        </button>
        <span class="topbar-title">Dashboard</span>
      </div>
      <div class="topbar-actions">
        <a href="/resume/new" class="btn btn-primary btn-sm">
          <i data-lucide="plus" style="width: 16px; height: 16px;"></i>
          <span>New Resume</span>
        </a>
        <a href="/dashboard/profile" class="nav-avatar">
          <% if (currentUser.avatar) { %>
            <img src="<%= currentUser.avatar %>" alt="Avatar" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover;">
          <% } else { %>
            <%= currentUser.name.charAt(0).toUpperCase() %>
          <% } %>
        </a>
      </div>
    </header>

    <!-- Page Content -->
    <div class="page-content">
      <%- include("../partials/flash") %>

      <% if (resumes.length === 0) { %>
        <!-- Hero Section - Empty State -->
        <div class="hero">
          <div class="hero-content">
            <div class="hero-badge">
              <i data-lucide="sparkles" style="width: 16px; height: 16px;"></i>
              <span>AI-Powered Resume Builder</span>
            </div>
            <h1 class="hero-title">Welcome back, <%= currentUser.name.split(' ')[0] %>!</h1>
            <p class="hero-subtitle">Create ATS-friendly resumes in minutes with our AI-powered tools and land your dream job faster.</p>
            <div class="hero-actions">
              <a href="/resume/new" class="btn btn-primary btn-lg">
                <i data-lucide="plus" style="width: 20px; height: 20px;"></i>
                <span>Create Resume</span>
              </a>
              <a href="/resume/ats-checker" class="btn btn-outline btn-lg">
                <i data-lucide="crosshair" style="width: 20px; height: 20px;"></i>
                <span>Check ATS Score</span>
              </a>
              <a href="/cover-letter/new" class="btn btn-outline btn-lg">
                <i data-lucide="mail" style="width: 20px; height: 20px;"></i>
                <span>Cover Letter</span>
              </a>
            </div>
          </div>
          <div class="hero-visual">
            <div class="hero-illustration">
              <div class="hero-circle hero-circle-1"></div>
              <div class="hero-circle hero-circle-2"></div>
              <i data-lucide="file-text" style="width: 64px; height: 64px;" class="hero-icon"></i>
            </div>
          </div>
        </div>
      <% } else { %>
        <!-- Hero Section - With Data -->
        <div class="hero" style="padding: 32px;">
          <div class="hero-content" style="flex: none;">
            <h1 class="hero-title" style="font-size: 1.75rem;">Welcome back, <%= currentUser.name.split(' ')[0] %>!</h1>
            <p class="hero-subtitle" style="margin-bottom: 0;">You have <%= stats.totalResumes %> resume<%= stats.totalResumes !== 1 ? 's' : '' %>. Keep building your career!</p>
          </div>
          <div class="hero-actions">
            <a href="/resume/new" class="btn btn-primary">
              <i data-lucide="plus" style="width: 16px; height: 16px;"></i>
              <span>New Resume</span>
            </a>
          </div>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
              <i data-lucide="file-text" style="width: 24px; height: 24px;"></i>
            </div>
            <div>
              <div class="stat-value"><%= stats.totalResumes %></div>
              <div class="stat-label">Total Resumes</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #10b981, #059669);">
              <i data-lucide="download" style="width: 24px; height: 24px;"></i>
            </div>
            <div>
              <div class="stat-value"><%= stats.totalDownloads %></div>
              <div class="stat-label">Downloads</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
              <i data-lucide="crosshair" style="width: 24px; height: 24px;"></i>
            </div>
            <div>
              <div class="stat-value"><%= stats.avgAtsScore %>%</div>
              <div class="stat-label">Avg ATS Score</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
              <i data-lucide="clock" style="width: 24px; height: 24px;"></i>
            </div>
            <div>
              <div class="stat-value" style="font-size: 1.5rem;"><%= stats.lastUpdated %></div>
              <div class="stat-label">Last Updated</div>
            </div>
          </div>
        </div>
      <% } %>

      <!-- Quick Actions -->
      <% if (resumes.length > 0) { %>
        <div style="background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: var(--radius); padding: 24px; margin-bottom: 32px;">
          <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--text-primary); margin-bottom: 16px;">Quick Actions</h3>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;">
            <a href="/resume/new" style="display: flex; align-items: center; gap: 12px; padding: 16px; background: var(--bg-tertiary); border-radius: var(--radius-sm); text-decoration: none; color: var(--text-primary); transition: all 0.2s;" onmouseover="this.style.background='var(--bg-secondary)'; this.style.transform='translateY(-2px)'" onmouseout="this.style.background='var(--bg-tertiary)'; this.style.transform='translateY(0)'">
              <i data-lucide="file-plus" style="width: 24px; height: 24px; color: var(--primary);"></i>
              <div>
                <div style="font-weight: 600; font-size: 0.875rem;">New Resume</div>
                <div style="font-size: 0.75rem; color: var(--text-tertiary);">Start from scratch</div>
              </div>
            </a>
            <a href="/cover-letter/new" style="display: flex; align-items: center; gap: 12px; padding: 16px; background: var(--bg-tertiary); border-radius: var(--radius-sm); text-decoration: none; color: var(--text-primary); transition: all 0.2s;" onmouseover="this.style.background='var(--bg-secondary)'; this.style.transform='translateY(-2px)'" onmouseout="this.style.background='var(--bg-tertiary)'; this.style.transform='translateY(0)'">
              <i data-lucide="mail" style="width: 24px; height: 24px; color: var(--success);"></i>
              <div>
                <div style="font-weight: 600; font-size: 0.875rem;">Cover Letter</div>
                <div style="font-size: 0.75rem; color: var(--text-tertiary);">AI-powered writing</div>
              </div>
            </a>
            <a href="/resume/ats-checker" style="display: flex; align-items: center; gap: 12px; padding: 16px; background: var(--bg-tertiary); border-radius: var(--radius-sm); text-decoration: none; color: var(--text-primary); transition: all 0.2s;" onmouseover="this.style.background='var(--bg-secondary)'; this.style.transform='translateY(-2px)'" onmouseout="this.style.background='var(--bg-tertiary)'; this.style.transform='translateY(0)'">
              <i data-lucide="target" style="width: 24px; height: 24px; color: var(--warning);"></i>
              <div>
                <div style="font-weight: 600; font-size: 0.875rem;">ATS Checker</div>
                <div style="font-size: 0.75rem; color: var(--text-tertiary);">Check your score</div>
              </div>
            </a>
            <a href="/interview" style="display: flex; align-items: center; gap: 12px; padding: 16px; background: var(--bg-tertiary); border-radius: var(--radius-sm); text-decoration: none; color: var(--text-primary); transition: all 0.2s;" onmouseover="this.style.background='var(--bg-secondary)'; this.style.transform='translateY(-2px)'" onmouseout="this.style.background='var(--bg-tertiary)'; this.style.transform='translateY(0)'">
              <i data-lucide="message-square" style="width: 24px; height: 24px; color: #8b5cf6;"></i>
              <div>
                <div style="font-weight: 600; font-size: 0.875rem;">Interview Prep</div>
                <div style="font-size: 0.75rem; color: var(--text-tertiary);">Practice questions</div>
              </div>
            </a>
          </div>
        </div>
      <% } %>

      <!-- Section Header -->
      <div class="section-header">
        <div>
          <h2 class="section-title">My Resumes</h2>
          <p class="section-subtitle">Manage and edit your professional resumes</p>
        </div>
        <% if (resumes.length > 0) { %>
          <a href="/resume/new" class="btn btn-primary">
            <i data-lucide="plus" style="width: 16px; height: 16px;"></i>
            <span>Add New</span>
          </a>
        <% } %>
      </div>

      <% if (resumes.length === 0) { %>
        <!-- Empty State -->
        <div class="empty-state">
          <div class="empty-state-icon">📄</div>
          <h3 class="empty-state-title">No resumes yet</h3>
          <p class="empty-state-description">Create your first professional resume with AI-powered suggestions and start landing your dream job.</p>
          <a href="/resume/new" class="btn btn-primary btn-lg">
            <i data-lucide="plus" style="width: 20px; height: 20px;"></i>
            <span>Create My First Resume</span>
          </a>
        </div>
      <% } else { %>
        <!-- Resume Grid -->
        <div class="resume-grid">
          <% resumes.forEach(function(resume){ %>
          <div class="resume-card">
            <div class="resume-card-header">
              <div class="resume-template">
                <i data-lucide="palette" style="width: 16px; height: 16px;"></i>
                <span><%= resume.template ? resume.template.charAt(0).toUpperCase() + resume.template.slice(1) : 'Modern' %></span>
              </div>
              <button class="btn btn-outline btn-sm" onclick="toggleMenu(event,'<%= resume._id %>')">
                <i data-lucide="more-horizontal" style="width: 16px; height: 16px;"></i>
              </button>
            </div>
            <div class="resume-card-body">
              <h3 class="resume-card-title"><%= resume.title %></h3>
              <div class="resume-card-meta">
                <%= resume.personalInfo && resume.personalInfo.fullName ? resume.personalInfo.fullName : 'Name not set' %>
                <% if (resume.personalInfo && resume.personalInfo.jobTitle) { %>
                  • <%= resume.personalInfo.jobTitle %>
                <% } %>
              </div>
              <div class="resume-card-stats">
                <div class="resume-stat">
                  <i data-lucide="target" style="width: 16px; height: 16px;"></i>
                  <span><%= resume.atsScore || 0 %>% ATS</span>
                </div>
                <div class="resume-stat">
                  <i data-lucide="download" style="width: 16px; height: 16px;"></i>
                  <span><%= resume.downloads || 0 %></span>
                </div>
                <div class="resume-stat">
                  <i data-lucide="calendar" style="width: 16px; height: 16px;"></i>
                  <span><%= new Date(resume.updatedAt).toLocaleDateString('en-US',{month:'short',day:'numeric'}) %></span>
                </div>
              </div>
            </div>
            <div class="resume-card-footer">
              <a href="/resume/<%= resume._id %>/edit" class="btn btn-primary btn-sm">
                <i data-lucide="edit" style="width: 14px; height: 14px;"></i>
                <span>Edit</span>
              </a>
              <a href="/resume/<%= resume._id %>/preview" class="btn btn-outline btn-sm">
                <i data-lucide="eye" style="width: 14px; height: 14px;"></i>
                <span>Preview</span>
              </a>
              <a href="/resume/<%= resume._id %>/download" class="btn btn-outline btn-sm">
                <i data-lucide="download" style="width: 14px; height: 14px;"></i>
                <span>PDF</span>
              </a>
            </div>
          </div>
          <% }) %>
        </div>

        <!-- Pagination -->
        <% if (pagination && pagination.totalPages > 1) { %>
          <div style="display: flex; justify-content: center; align-items: center; gap: 12px; margin: 24px 0;">
            <% if (pagination.hasPrev) { %>
              <a href="/dashboard?page=<%= pagination.page - 1 %>&search=<%= filters.search %>&template=<%= filters.template %>&sort=<%= filters.sort %>" class="btn btn-outline btn-sm">← Prev</a>
            <% } else { %>
              <button class="btn btn-outline btn-sm" disabled>← Prev</button>
            <% } %>
            <span style="font-size: 0.875rem; color: var(--text-secondary);">Page <%= pagination.page %> of <%= pagination.totalPages %></span>
            <% if (pagination.hasNext) { %>
              <a href="/dashboard?page=<%= pagination.page + 1 %>&search=<%= filters.search %>&template=<%= filters.template %>&sort=<%= filters.sort %>" class="btn btn-outline btn-sm">Next →</a>
            <% } else { %>
              <button class="btn btn-outline btn-sm" disabled>Next →</button>
            <% } %>
          </div>
        <% } %>
      <% } %>

      <!-- Cover Letters Section -->
      <% if (typeof coverLetters !== 'undefined' && coverLetters.length > 0) { %>
        <div class="section-header" style="margin-top: 48px;">
          <div>
            <h2 class="section-title">My Cover Letters</h2>
            <p class="section-subtitle">Personalized cover letters for your applications</p>
          </div>
          <a href="/cover-letter/new" class="btn btn-primary">
            <i data-lucide="plus" style="width: 16px; height: 16px;"></i>
            <span>Add New</span>
          </a>
        </div>

        <div class="resume-grid">
          <% coverLetters.forEach(function(cl){ %>
          <div class="resume-card">
            <div class="resume-card-header">
              <div class="resume-template">
                <i data-lucide="mail" style="width: 16px; height: 16px;"></i>
                <span>Cover Letter</span>
              </div>
            </div>
            <div class="resume-card-body">
              <h3 class="resume-card-title"><%= cl.title || 'Untitled Cover Letter' %></h3>
              <div class="resume-card-meta">
                <% if (cl.jobTitle) { %>
                  <%= cl.jobTitle %>
                <% } %>
                <% if (cl.company) { %>
                  • <%= cl.company %>
                <% } %>
              </div>
              <div class="resume-card-stats">
                <div class="resume-stat">
                  <i data-lucide="calendar" style="width: 16px; height: 16px;"></i>
                  <span><%= new Date(cl.updatedAt).toLocaleDateString('en-US',{month:'short',day:'numeric'}) %></span>
                </div>
              </div>
            </div>
            <div class="resume-card-footer">
              <a href="/cover-letter/<%= cl._id %>/edit" class="btn btn-primary btn-sm">
                <i data-lucide="edit" style="width: 14px; height: 14px;"></i>
                <span>Edit</span>
              </a>
              <a href="/cover-letter/<%= cl._id %>/preview" class="btn btn-outline btn-sm">
                <i data-lucide="eye" style="width: 14px; height: 14px;"></i>
                <span>Preview</span>
              </a>
              <a href="/cover-letter/<%= cl._id %>/download" class="btn btn-outline btn-sm">
                <i data-lucide="download" style="width: 14px; height: 14px;"></i>
                <span>PDF</span>
              </a>
            </div>
          </div>
          <% }) %>
        </div>
      <% } else if (resumes.length > 0) { %>
        <!-- Cover Letter CTA -->
        <div class="section-header" style="margin-top: 48px;">
          <div>
            <h2 class="section-title">Cover Letters</h2>
            <p class="section-subtitle">Boost your application with a personalized cover letter</p>
          </div>
        </div>
        <div style="background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: var(--radius); padding: 48px; text-align: center;">
          <i data-lucide="mail" style="width: 64px; height: 64px; margin: 0 auto 16px; color: var(--primary);"></i>
          <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 8px;">Create Your First Cover Letter</h3>
          <p style="color: var(--text-secondary); margin-bottom: 24px;">Stand out with AI-powered cover letters tailored to each job application.</p>
          <a href="/cover-letter/new" class="btn btn-primary">
            <i data-lucide="plus" style="width: 16px; height: 16px;"></i>
            <span>Create Cover Letter</span>
          </a>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
// Initialize Lucide icons
if (typeof lucide !== 'undefined') {
  lucide.createIcons();
  console.log('✅ Lucide icons initialized');
} else {
  console.error('❌ Lucide library not loaded');
}

// Sidebar toggle
const sidebar = document.getElementById('sidebar');
const sidebarToggle = document.getElementById('sidebarToggle');
const sidebarCollapse = document.getElementById('sidebarCollapse');

if (sidebarToggle) {
  sidebarToggle.addEventListener('click', () => {
    sidebar.classList.toggle('open');
  });
}

if (sidebarCollapse) {
  sidebarCollapse.addEventListener('click', () => {
    sidebar.classList.toggle('collapsed');
  });
}

// Mobile sidebar close
document.addEventListener('click', (e) => {
  if (window.innerWidth <= 1024 && 
      sidebar.classList.contains('open') && 
      !sidebar.contains(e.target) && 
      !sidebarToggle.contains(e.target)) {
    sidebar.classList.remove('open');
  }
});

function toggleMenu(event, id) {
  // Dropdown menu for resume actions
  const existingMenu = document.querySelector('.resume-action-menu');
  if (existingMenu) {
    existingMenu.remove();
    return;
  }

  const menu = document.createElement('div');
  menu.className = 'resume-action-menu';
  menu.style.cssText = `
    position: fixed;
    background: white;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-lg);
    padding: 8px;
    z-index: 1000;
    min-width: 200px;
  `;

  const actions = [
    { icon: 'edit', label: 'Edit', href: `/resume/${id}/edit` },
    { icon: 'eye', label: 'Preview', href: `/resume/${id}/preview` },
    { icon: 'download', label: 'Download PDF', href: `/resume/${id}/download` },
    { icon: 'copy', label: 'Duplicate', href: '#', onclick: `duplicateResume('${id}')` },
    { icon: 'share-2', label: 'Share', href: `/resume/${id}/share` },
    { icon: 'trash-2', label: 'Delete', href: '#', onclick: `deleteResume('${id}')`, class: 'danger' }
  ];

  actions.forEach(action => {
    const item = document.createElement('a');
    item.href = action.href;
    if (action.onclick) {
      item.onclick = (e) => {
        e.preventDefault();
        eval(action.onclick);
        menu.remove();
      };
    }
    item.style.cssText = `
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 12px;
      color: ${action.class === 'danger' ? 'var(--danger)' : 'var(--text-primary)'};
      text-decoration: none;
      border-radius: 6px;
      font-size: 0.875rem;
      transition: background 0.2s;
    `;
    item.onmouseover = () => item.style.background = 'var(--bg-tertiary)';
    item.onmouseout = () => item.style.background = 'transparent';
    item.innerHTML = `<i data-lucide="${action.icon}" style="width: 16px; height: 16px;"></i><span>${action.label}</span>`;
    menu.appendChild(item);
  });

  document.body.appendChild(menu);
  
  // Position menu near clicked button
  const button = event.target.closest('button');
  const rect = button.getBoundingClientRect();
  menu.style.top = (rect.bottom + 5) + 'px';
  menu.style.right = (window.innerWidth - rect.right) + 'px';
  
  // Re-initialize Lucide icons
  if (typeof lucide !== 'undefined') {
    lucide.createIcons();
  }

  // Close menu when clicking outside
  setTimeout(() => {
    document.addEventListener('click', function closeMenu(e) {
      if (!menu.contains(e.target)) {
        menu.remove();
        document.removeEventListener('click', closeMenu);
      }
    });
  }, 0);
}

function duplicateResume(id) {
  if (confirm('Create a copy of this resume?')) {
    fetch(`/resume/${id}/duplicate`, { method: 'POST' })
      .then(res => {
        if (res.ok) {
          window.location.reload();
        } else {
          alert('Failed to duplicate resume');
        }
      })
      .catch(() => alert('Failed to duplicate resume'));
  }
}

function deleteResume(id) {
  if (confirm('Move this resume to trash? You can restore it later.')) {
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = `/resume/${id}?_method=DELETE`;
    document.body.appendChild(form);
    form.submit();
  }
}

// Re-initialize icons after any dynamic content changes
const observer = new MutationObserver(() => {
  if (typeof lucide !== 'undefined') {
    lucide.createIcons();
  }
});

observer.observe(document.body, {
  childList: true,
  subtree: true
});

console.log('🎨 Dashboard initialized successfully');
</script>

<%- include("../partials/closing") %>
