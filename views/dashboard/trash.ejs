<%- include("../partials/header") %>

<div class="dashboard-layout">

  <!-- ═══ SIDEBAR ══════════════════════════════════════════════ -->
  <aside class="sidebar" id="dashSidebar">
    <div class="sidebar-logo">
      <a href="/">
        <span class="brand-icon-wrap"><i class="fas fa-bolt"></i></span>
        <span>ResumeAI<span style="color:var(--accent)">.</span></span>
      </a>
    </div>

    <nav class="sidebar-nav">
      <span class="sidebar-nav-section">Main</span>
      <a href="/dashboard" class="sidebar-nav-item">
        <i class="fas fa-th-large"></i> Dashboard
      </a>
      <a href="/resume/new" class="sidebar-nav-item">
        <i class="fas fa-plus-circle"></i> New Resume
      </a>

      <span class="sidebar-nav-section" style="margin-top:12px">Manage</span>
      <a href="/dashboard" class="sidebar-nav-item">
        <i class="fas fa-folder-open"></i> My Resumes
      </a>
      <a href="/dashboard/trash" class="sidebar-nav-item active">
        <i class="fas fa-trash-alt"></i> Trash
        <% if (typeof trashCount !== 'undefined' && trashCount > 0) { %>
          <span style="margin-left:auto;background:var(--danger);color:white;font-size:11px;font-weight:700;padding:2px 7px;border-radius:50px;"><%= trashCount %></span>
        <% } %>
      </a>

      <span class="sidebar-nav-section" style="margin-top:12px">Account</span>
      <a href="/dashboard/profile" class="sidebar-nav-item">
        <i class="fas fa-user-circle"></i> Profile
      </a>
      <a href="/dashboard/profile" class="sidebar-nav-item">
        <i class="fas fa-cog"></i> Settings
      </a>
    </nav>

    <div class="sidebar-footer">
      <% if (currentUser) { %>
        <div class="sidebar-user">
          <% if (currentUser.avatar) { %>
            <img src="<%= currentUser.avatar %>" alt="Avatar" class="sidebar-user-avatar"
              style="width:36px;height:36px;border-radius:50%;object-fit:cover;">
          <% } else { %>
            <div class="sidebar-user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></div>
          <% } %>
          <div style="overflow:hidden">
            <div class="sidebar-user-name"><%= currentUser.name %></div>
            <div class="sidebar-user-email"><%= currentUser.email %></div>
          </div>
        </div>
      <% } %>
      <a href="/auth/logout" class="sidebar-logout">
        <i class="fas fa-sign-out-alt"></i> Logout
      </a>
    </div>
  </aside>

  <!-- ═══ MAIN CONTENT ════════════════════════════════════════ -->
  <div class="dashboard-main">

    <!-- TOP BAR -->
    <header class="topbar">
      <div style="display:flex;align-items:center;gap:14px">
        <button class="sidebar-toggle-btn" id="sidebarToggle" aria-label="Toggle sidebar">
          <i class="fas fa-bars"></i>
        </button>
        <span class="topbar-title">
          <i class="fas fa-trash-alt" style="color:var(--danger);margin-right:6px;"></i> Trash
        </span>
      </div>
      <div class="topbar-actions">
        <a href="/dashboard" class="btn btn-outline btn-sm">
          <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
      </div>
    </header>

    <!-- PAGE CONTENT -->
    <div class="page-content">
      <%- include("../partials/flash") %>

      <% if (!resumes || resumes.length === 0) { %>

        <!-- EMPTY TRASH STATE -->
        <div style="text-align:center;padding:80px 20px;">
          <div style="width:90px;height:90px;background:#FEE2E2;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
            <i class="fas fa-trash-alt" style="font-size:36px;color:var(--danger);"></i>
          </div>
          <h3 style="font-size:22px;font-weight:700;color:var(--dark);margin-bottom:8px;">Trash is empty</h3>
          <p style="color:var(--muted);font-size:15px;margin-bottom:28px;">
            Deleted resumes will appear here.<br>You can restore them or permanently delete them.
          </p>
          <a href="/dashboard" class="btn btn-primary">
            <i class="fas fa-th-large"></i> Back to Dashboard
          </a>
        </div>

      <% } else { %>

        <!-- INFO BAR -->
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;background:var(--white);padding:14px 20px;border-radius:var(--radius);border:1.5px solid #FEE2E2;">
          <p style="color:var(--muted);font-size:14px;margin:0;">
            <i class="fas fa-info-circle" style="color:var(--warning);margin-right:6px;"></i>
            <strong><%= resumes.length %></strong> resume<%= resumes.length !== 1 ? 's' : '' %> in Trash.
            Restore or permanently delete them below.
          </p>
        </div>

        <!-- TRASH GRID -->
        <div class="resume-grid">
          <% resumes.forEach(function(resume) { %>
          <div class="resume-card" style="opacity:0.88;">

            <!-- Red top bar -->
            <div style="height:4px;background:var(--danger);border-radius:var(--radius-lg) var(--radius-lg) 0 0;"></div>

            <div class="resume-card-inner">

              <!-- Card Header -->
              <div class="resume-card-header">
                <span style="font-size:12px;font-weight:600;padding:4px 10px;border-radius:50px;background:rgba(239,68,68,0.1);color:var(--danger);display:inline-flex;align-items:center;gap:6px;">
                  <i class="fas fa-trash-alt"></i>
                  <%= resume.template ? resume.template.charAt(0).toUpperCase() + resume.template.slice(1) : 'Resume' %>
                </span>
              </div>

              <!-- Card Body -->
              <div class="resume-card-body">
                <h3 class="resume-title"><%= resume.title %></h3>
                <p class="resume-person-name">
                  <i class="fas fa-user"></i>
                  <%= (resume.personalInfo && resume.personalInfo.fullName) ? resume.personalInfo.fullName : 'Name not set' %>
                </p>
                <% if (resume.personalInfo && resume.personalInfo.jobTitle) { %>
                  <p class="resume-job-title">
                    <i class="fas fa-briefcase"></i> <%= resume.personalInfo.jobTitle %>
                  </p>
                <% } %>
                <p class="resume-meta" style="margin-top:6px;">
                  <i class="fas fa-calendar-times" style="color:var(--danger);"></i>
                  Deleted: <%= resume.deletedAt
                    ? new Date(resume.deletedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
                    : 'Unknown date' %>
                </p>
              </div>

              <!-- Card Footer Actions -->
              <div class="resume-card-footer" style="gap:8px;flex-wrap:wrap;">

                <!-- RESTORE -->
                <form action="/resume/<%= resume._id %>/restore" method="POST" style="margin:0;">
                  <button type="submit" class="btn btn-sm btn-outline"
                    style="color:var(--success);border-color:var(--success);">
                    <i class="fas fa-undo-alt"></i> Restore
                  </button>
                </form>

                <!-- PERMANENT DELETE -->
                <form
                  action="/resume/<%= resume._id %>/permanent?_method=DELETE"
                  method="POST"
                  onsubmit="return confirm('Permanently delete this resume? This cannot be undone.')"
                  style="margin:0;">
                  <button type="submit" class="btn btn-sm btn-danger">
                    <i class="fas fa-times-circle"></i> Delete Forever
                  </button>
                </form>

              </div>
            </div>
          </div>
          <% }) %>
        </div>

      <% } %>
    </div><!-- /.page-content -->
  </div><!-- /.dashboard-main -->
</div><!-- /.dashboard-layout -->

<script>
  // Sidebar toggle (same pattern as dashboard)
  var sidebarToggle = document.getElementById('sidebarToggle');
  var dashSidebar   = document.getElementById('dashSidebar');
  if (sidebarToggle && dashSidebar) {
    sidebarToggle.addEventListener('click', function () {
      dashSidebar.classList.toggle('sidebar-open');
    });
    document.addEventListener('click', function (e) {
      if (dashSidebar.classList.contains('sidebar-open') &&
          !dashSidebar.contains(e.target) &&
          !sidebarToggle.contains(e.target)) {
        dashSidebar.classList.remove('sidebar-open');
      }
    });
  }
</script>

<%- include("../partials/closing") %>
