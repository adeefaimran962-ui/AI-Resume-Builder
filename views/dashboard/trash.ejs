<%- include("../partials/header") %>

<div class="dashboard-layout">

  <!-- ═══ SIDEBAR ══════════════════════════════════════════════ -->
  <aside class="sidebar" id="dashSidebar">
    <div class="sidebar-logo">
      <a href="/">
        <span class="brand-icon-wrap"><i class="fas fa-bolt"></i></span>
        <span>ResumeAI<span style="color:var(--accent)">.</span></span>
      </a>
    </div>
    <nav class="sidebar-nav">
      <span class="sidebar-nav-section">Main</span>
      <a href="/dashboard" class="sidebar-nav-item"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/resume/new" class="sidebar-nav-item"><i class="fas fa-plus-circle"></i> New Resume</a>

      <span class="sidebar-nav-section" style="margin-top:12px">Manage</span>
      <a href="/dashboard" class="sidebar-nav-item"><i class="fas fa-folder-open"></i> My Resumes</a>
      <a href="/dashboard/trash" class="sidebar-nav-item active">
        <i class="fas fa-trash-alt"></i> Trash
        <% if (trashCount > 0) { %>
          <span style="margin-left:auto;background:var(--danger);color:white;font-size:11px;font-weight:700;padding:2px 7px;border-radius:50px;"><%= trashCount %></span>
        <% } %>
      </a>

      <span class="sidebar-nav-section" style="margin-top:12px">Account</span>
      <a href="/dashboard/profile" class="sidebar-nav-item"><i class="fas fa-user-circle"></i> Profile</a>
    </nav>
    <div class="sidebar-footer">
      <div class="sidebar-user">
        <% if (currentUser.avatar) { %>
          <img src="<%= currentUser.avatar %>" alt="Avatar" class="sidebar-user-avatar" style="width:36px;height:36px;border-radius:50%;object-fit:cover;">
        <% } else { %>
          <div class="sidebar-user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></div>
        <% } %>
        <div style="overflow:hidden">
          <div class="sidebar-user-name"><%= currentUser.name %></div>
          <div class="sidebar-user-email"><%= currentUser.email %></div>
        </div>
      </div>
      <a href="/auth/logout" class="sidebar-logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>
  </aside>

  <!-- ═══ MAIN CONTENT ════════════════════════════════════════ -->
  <div class="dashboard-main">
    <header class="topbar">
      <div style="display:flex;align-items:center;gap:14px">
        <button class="sidebar-toggle-btn" id="sidebarToggle" aria-label="Toggle sidebar">
          <i class="fas fa-bars"></i>
        </button>
        <span class="topbar-title"><i class="fas fa-trash-alt" style="color:var(--danger);margin-right:8px;"></i> Trash</span>
      </div>
      <div class="topbar-actions">
        <a href="/dashboard" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i> Back to Dashboard</a>
      </div>
    </header>

    <div class="page-content">
      <%- include("../partials/flash") %>

      <% if (resumes.length === 0) { %>
        <div class="empty-state" style="padding:80px 20px;text-align:center;">
          <div style="width:80px;height:80px;background:#FEE2E2;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
            <i class="fas fa-trash-alt" style="font-size:32px;color:var(--danger);"></i>
          </div>
          <h3 style="font-size:20px;font-weight:700;color:var(--dark);margin-bottom:8px;">Trash is empty</h3>
          <p style="color:var(--muted);font-size:15px;">Deleted resumes will appear here. You can restore or permanently delete them.</p>
          <a href="/dashboard" class="btn btn-primary" style="margin-top:20px;"><i class="fas fa-th-large"></i> Back to Dashboard</a>
        </div>

      <% } else { %>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
          <p style="color:var(--muted);font-size:14px;margin:0;">
            <i class="fas fa-info-circle" style="color:var(--warning);"></i>
            Trashed resumes are kept here until you permanently delete them.
          </p>
        </div>

        <div class="resume-grid">
          <% resumes.forEach(function(resume) { %>
          <div class="resume-card" style="opacity:0.85;">
            <div style="height:4px;background:var(--danger);"></div>
            <div class="resume-card-inner">

              <div class="resume-card-header">
                <span style="font-size:12px;font-weight:600;padding:4px 8px;border-radius:4px;background:rgba(239,68,68,0.1);color:var(--danger);display:inline-flex;align-items:center;gap:6px;">
                  <i class="fas fa-trash-alt"></i> Deleted
                </span>
              </div>

              <div class="resume-card-body">
                <h3 class="resume-title"><%= resume.title %></h3>
                <p class="resume-person-name">
                  <i class="fas fa-user"></i>
                  <%= resume.personalInfo && resume.personalInfo.fullName ? resume.personalInfo.fullName : 'Name not set' %>
                </p>
                <p class="resume-meta" style="margin-top:4px;">
                  <i class="fas fa-calendar-times" style="color:var(--danger);"></i>
                  Deleted <%= resume.deletedAt ? new Date(resume.deletedAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : 'recently' %>
                </p>
              </div>

              <div class="resume-card-footer" style="gap:8px;">
                <!-- Restore -->
                <form action="/resume/<%= resume._id %>/restore" method="POST" style="margin:0;">
                  <button type="submit" class="btn btn-outline btn-sm" style="color:var(--success);border-color:var(--success);">
                    <i class="fas fa-undo"></i> Restore
                  </button>
                </form>
                <!-- Permanently Delete -->
                <form action="/resume/<%= resume._id %>/permanent?_method=DELETE" method="POST"
                  onsubmit="return confirm('Permanently delete \'<%= resume.title.replace(/'/g, \"&#39;\") %>\'? This cannot be undone.')"
                  style="margin:0;">
                  <button type="submit" class="btn btn-danger btn-sm">
                    <i class="fas fa-times"></i> Delete Forever
                  </button>
                </form>
              </div>

            </div>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include("../partials/closing") %>
