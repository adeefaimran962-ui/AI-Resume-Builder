<%- include("../partials/header") %>
<%- include("../partials/navbar") %>
<main class="auth-page">
  <div class="container">
    <div class="glass-card glass-card-dark auth-card animate-fade-in-up">
      <div class="auth-header">
        <div class="auth-icon glass-badge"><i class="fas fa-sign-in-alt"></i></div>
        <h1>Welcome Back</h1>
        <p>Sign in to manage your resumes</p>
      </div>
      <%- include("../partials/flash") %>
      <% if (errors && errors.length) { %>
        <div class="alert alert-error">
          <ul class="error-list">
            <% errors.forEach(e => { %><li><i class="fas fa-exclamation-circle"></i> <%= e %></li><% }) %>
          </ul>
        </div>
      <% } %>
      <form action="/auth/login" method="POST" class="auth-form" novalidate>
        <div class="form-group">
          <label for="email" class="form-label">Email Address</label>
          <div class="input-wrapper">
            <i class="fas fa-envelope input-icon"></i>
            <input type="email" id="email" name="email" class="glass-input-dark input" placeholder="john@example.com"
              value="<%= formData.email || "" %>" required autocomplete="email" />
          </div>
        </div>
        <div class="form-group">
          <label for="password" class="form-label">Password</label>
          <div class="input-wrapper">
            <i class="fas fa-lock input-icon"></i>
            <input type="password" id="password" name="password" class="glass-input-dark input"
              placeholder="Your password" required autocomplete="current-password" />
          </div>
        </div>
        <div class="form-group" style="text-align: right;">
          <a href="/auth/forgot-password" class="hover-underline">Forgot Password?</a>
        </div>
        <button type="submit" class="btn btn-primary btn-lg btn-block hover-lift">
          <i class="fas fa-sign-in-alt"></i> Sign In
        </button>
      </form>
      <p class="auth-footer">No account yet? <a href="/auth/register" class="hover-underline">Create one free</a></p>
    </div>
  </div>
</main>
<%- include("../partials/footer") %>
